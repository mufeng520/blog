---
interface Props {
  toolName: string;
  toolType?: string;
  accent?: string;
}

const { toolName, toolType = 'AI 工具', accent = '#4d9273' } = Astro.props;
---

<div class="mufeng-tool-bar" style={`--mufeng-tool-accent:${accent};`}>
  <a class="mufeng-tool-bar__home" href="/" aria-label="返回首页">
    <img src="/favicon.ico" alt="" width="22" height="22" />
    <span>木风</span>
  </a>
  <span class="mufeng-tool-bar__sep">·</span>
  <a class="mufeng-tool-bar__crumb" href="/tools/">工具箱</a>
  <span class="mufeng-tool-bar__sep">/</span>
  <span class="mufeng-tool-bar__title">{toolName}</span>
  <span class="mufeng-tool-bar__type">{toolType}</span>
</div>

<style is:global>
  .mufeng-tool-bar {
    position: fixed;
    bottom: 16px;
    left: 16px;
    z-index: 9999;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 14px 6px 8px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(142, 175, 156, 0.22);
    box-shadow: 0 14px 32px rgba(89, 124, 106, 0.18);
    backdrop-filter: blur(16px);
    font-family: "Outfit", "PingFang SC", "Microsoft YaHei", sans-serif;
    font-size: 0.78rem;
    color: #6c7f75;
    line-height: 1;
    max-width: calc(100% - 32px);
    overflow: hidden;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .mufeng-tool-bar:hover {
    transform: translateY(-1px);
  }

  .mufeng-tool-bar__home {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 10px 4px 4px;
    border-radius: 999px;
    color: #24332d;
    background: rgba(105, 179, 143, 0.12);
    text-decoration: none;
    font-weight: 600;
    transition: background 0.2s ease;
  }

  .mufeng-tool-bar__home:hover {
    background: rgba(105, 179, 143, 0.22);
  }

  .mufeng-tool-bar__home img {
    border-radius: 6px;
  }

  .mufeng-tool-bar__sep {
    color: rgba(108, 127, 117, 0.5);
  }

  .mufeng-tool-bar__crumb {
    color: #4d9273;
    text-decoration: none;
    padding: 4px 6px;
    border-radius: 8px;
    transition: background 0.2s ease;
  }

  .mufeng-tool-bar__crumb:hover {
    background: rgba(105, 179, 143, 0.12);
  }

  .mufeng-tool-bar__title {
    color: #24332d;
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 220px;
  }

  .mufeng-tool-bar__type {
    margin-left: 4px;
    padding: 3px 8px;
    border-radius: 999px;
    background: var(--mufeng-tool-accent, #4d9273);
    color: #fff;
    font-size: 0.68rem;
    letter-spacing: 0.04em;
  }

  @media (max-width: 640px) {
    .mufeng-tool-bar {
      font-size: 0.72rem;
      padding: 5px 10px 5px 5px;
    }
    .mufeng-tool-bar__title {
      max-width: 120px;
    }
    .mufeng-tool-bar__type {
      display: none;
    }
  }
</style>
