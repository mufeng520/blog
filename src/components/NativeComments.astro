---
interface Props {
  pageSize?: number;
}

const { pageSize = 10 } = Astro.props;
---

<div class="native-comments" data-native-comments data-page-size={pageSize}>
  <div class="native-comments-status" data-comments-status>评论区加载中...</div>

  <h3 class="native-comments-compose-title">说点什么</h3>
  <form class="native-comments-form" data-comment-form>
    <div class="native-comments-replying" data-replying hidden>
      <span data-replying-text></span>
      <button type="button" data-cancel-reply>取消回复</button>
    </div>

    <div class="native-comments-fields">
      <label>
        <span>名称：可选，用于展示身份</span>
        <input name="nick" maxlength="32" autocomplete="nickname" />
      </label>
      <label>
        <span>邮箱：可选，用于头像</span>
        <input name="mail" type="email" maxlength="120" autocomplete="email" />
      </label>
      <label>
        <span>网站：可选，用于引导访问</span>
        <input name="link" type="url" maxlength="240" autocomplete="url" placeholder="https://" />
      </label>
    </div>

    <label class="native-comments-content">
      <span class="native-comments-content-label">还在等什么？来都来了，键盘敲起。</span>
      <textarea name="content" maxlength="1000" rows="6" required></textarea>
    </label>

    <label class="native-comments-hp" aria-hidden="true">
      <span>Website</span>
      <input name="honeyPot" tabindex="-1" autocomplete="off" />
    </label>

    <input type="hidden" name="parentId" />
    <input type="hidden" name="startedAt" />

    <div class="native-comments-actions">
      <span class="native-comments-hint">支持 Markdown、预设表情、剧透语法，如 || 剧透内容 ||</span>
      <span class="native-comments-count"><span data-comment-count>0</span> / 1000</span>
      <button type="submit">
        <span>提交留言</span>
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M21 3 10 14"></path>
          <path d="m21 3-7 18-4-7-7-4 18-7Z"></path>
        </svg>
      </button>
    </div>
  </form>

  <h3 class="native-comments-list-title">大家在聊 <span data-comments-total></span></h3>
  <div class="native-comments-list" data-comments-list></div>

  <button class="native-comments-load-more" type="button" data-load-more hidden>
    加载更多
  </button>
</div>

<style is:global>
  .native-comments {
    display: grid;
    gap: 20px;
    width: min(100%, 1080px);
    margin-inline: auto;
    --comment-border: rgba(17, 24, 39, 0.12);
    --comment-border-strong: rgba(17, 24, 39, 0.2);
    --comment-bg: rgba(255, 255, 255, 0.92);
    --comment-bg-soft: rgba(249, 250, 251, 0.82);
    --comment-text: #111827;
    --comment-muted: #6b7280;
    --comment-muted-soft: #9ca3af;
    --comment-primary: #4d9273;
    --comment-primary-soft: rgba(105, 179, 143, 0.1);
  }

  .native-comments-compose-title,
  .native-comments-list-title {
    margin: 0;
    color: var(--comment-text);
    font-size: 1.16rem;
    font-weight: 700;
    line-height: 1.35;
  }

  .native-comments-list-title {
    margin-top: 12px;
  }

  .native-comments-list-title span {
    color: var(--comment-muted);
    font-weight: 600;
  }

  .native-comments-status {
    padding: 12px 14px;
    border-radius: 8px;
    background: rgba(255, 248, 235, 0.88);
    border: 1px solid rgba(229, 193, 123, 0.28);
    color: #7a6540;
    font-size: 0.86rem;
    line-height: 1.7;
  }

  .native-comments-status.is-ok {
    display: none;
  }

  .native-comments-form,
  .native-comment {
    border: 1px solid var(--comment-border);
    border-radius: 8px;
    background: var(--comment-bg);
    box-shadow: none;
  }

  .native-comments-form {
    display: grid;
    gap: 0;
    padding: 0;
    overflow: hidden;
  }

  .native-comments-replying {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 10px 14px;
    border-radius: 0;
    background: var(--comment-primary-soft);
    color: var(--comment-primary);
    font-size: 0.86rem;
  }

  .native-comments-replying[hidden],
  .native-comments-load-more[hidden] {
    display: none;
  }

  .native-comments-replying button,
  .native-comments-actions button,
  .native-comments-load-more,
  .native-comment-toggle-replies,
  .native-comment-reply-btn {
    border: none;
    border-radius: 6px;
    font: inherit;
    cursor: pointer;
    transition: transform 0.16s ease, background 0.18s ease, color 0.18s ease, border-color 0.18s ease;
  }

  .native-comments-replying button {
    padding: 6px 10px;
    color: var(--comment-primary);
    background: rgba(105, 179, 143, 0.12);
    font-size: 0.8rem;
  }

  .native-comments-replying button:hover {
    background: rgba(105, 179, 143, 0.18);
  }

  .native-comments-fields {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0;
    border-bottom: 1px solid var(--comment-border);
  }

  .native-comments-form label {
    display: grid;
    gap: 8px;
    min-width: 0;
    color: #5f6f66;
    font-size: 0.84rem;
    font-weight: 600;
  }

  .native-comments-fields label {
    padding: 16px 18px 14px;
  }

  .native-comments-fields label + label {
    border-left: 1px solid rgba(142, 175, 156, 0.14);
  }

  .native-comments-form input,
  .native-comments-form textarea {
    width: 100%;
    border: none;
    border-radius: 0;
    background: transparent;
    color: var(--comment-text);
    font: inherit;
    font-weight: 400;
    transition: border-color 0.22s ease, box-shadow 0.22s ease;
  }

  .native-comments-form input {
    height: 28px;
    padding: 0;
  }

  .native-comments-form textarea {
    min-height: 152px;
    padding: 18px;
    resize: vertical;
  }

  .native-comments-form input:focus,
  .native-comments-form textarea:focus {
    outline: none;
    box-shadow: none;
  }

  .native-comments-form input::placeholder,
  .native-comments-form textarea::placeholder {
    color: #8b9993;
  }

  .native-comments-hp {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .native-comments-actions {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 16px;
    padding: 12px 18px 16px;
    border-top: 1px solid var(--comment-border);
  }

  .native-comments-hint {
    margin-right: auto;
    color: #7c9287;
    font-size: 0.82rem;
  }

  .native-comments-count {
    color: #6f8278;
    font-size: 0.84rem;
    white-space: nowrap;
  }

  .native-comments-actions button,
  .native-comments-load-more {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 7px;
    min-height: 34px;
    padding: 8px 13px;
    color: #fff;
    background: var(--comment-primary);
    border: 1px solid transparent;
    font-weight: 600;
  }

  .native-comments-actions button svg {
    width: 15px;
    height: 15px;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2;
  }

  .native-comments-actions button:hover,
  .native-comments-load-more:hover {
    background: #427f63;
  }

  .native-comments-actions button:disabled,
  .native-comments-load-more:disabled {
    cursor: not-allowed;
    opacity: 0.62;
    transform: none;
  }

  .native-comments-list {
    display: grid;
    gap: 18px;
  }

  .native-comments-empty {
    padding: 22px;
    border-radius: 8px;
    color: var(--comment-muted);
    background: var(--comment-bg-soft);
    border: 1px dashed rgba(142, 175, 156, 0.28);
    text-align: center;
  }

  .native-comment {
    padding: 24px;
    transition: border-color 0.18s ease, background 0.18s ease;
  }

  .native-comment:hover {
    border-color: var(--comment-border-strong);
  }

  .native-comment.is-reply {
    padding: 16px 0;
    border: none;
    border-radius: 0;
    background: transparent;
  }

  .native-comment.is-reply:hover {
    border-color: transparent;
  }

  .native-comment.is-reply + .native-comment.is-reply {
    border-top: 1px solid var(--comment-border);
  }

  .native-comment-header {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    margin-bottom: 0;
    min-width: 0;
  }

  .native-comment.is-reply .native-comment-header {
    gap: 12px;
  }

  .native-comment-avatar {
    position: relative;
    flex: 0 0 auto;
    display: grid;
    place-items: center;
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: #f3f4f6;
    border: 1px solid rgba(17, 24, 39, 0.08);
    overflow: hidden;
  }

  .native-comment.is-reply .native-comment-avatar {
    width: 40px;
    height: 40px;
  }

  .native-comment-avatar img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .native-comment-meta {
    min-width: 0;
    flex: 1;
  }

  .native-comment-author-line {
    display: flex;
    align-items: center;
    gap: 9px;
    min-width: 0;
  }

  .native-comment-detail {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 2px;
    color: var(--comment-muted-soft);
    font-size: 0.82rem;
    line-height: 1.45;
  }

  .native-comment-author {
    color: var(--comment-text);
    font-size: 1rem;
    font-weight: 650;
    text-decoration: none;
    overflow-wrap: anywhere;
  }

  .native-comment.is-reply .native-comment-author {
    font-size: 0.92rem;
  }

  .native-comment-author[href] {
    text-decoration-line: underline;
    text-decoration-style: dotted;
    text-underline-offset: 3px;
  }

  .native-comment-author[href]:hover {
    color: var(--comment-primary);
    text-decoration-style: solid;
  }

  .native-comment-time {
    color: inherit;
    font-size: inherit;
  }

  .native-comment-body {
    margin-top: 16px;
    color: #1f2937;
    font-size: 1rem;
    line-height: 1.76;
    word-break: break-word;
    min-height: 24px;
  }

  .native-comment.is-reply .native-comment-body {
    margin-top: 12px;
    font-size: 0.94rem;
    line-height: 1.72;
  }

  .native-comment-body p {
    margin: 0 0 10px;
  }

  .native-comment-body p:last-child {
    margin-bottom: 0;
  }

  .native-comment-body a {
    color: var(--comment-primary);
    text-decoration: none;
    border-bottom: 1px solid rgba(105, 179, 143, 0.24);
  }

  .native-comment-body code {
    padding: 2px 6px;
    border-radius: 6px;
    background: rgba(105, 179, 143, 0.12);
    color: #416d58;
    font-size: 0.88em;
  }

  .native-comment-body img {
    max-width: 100%;
    height: auto;
    border-radius: 6px;
    vertical-align: middle;
  }

  .native-comment-body img.emoji {
    display: inline-block;
    width: 80px;
    height: 80px;
    margin: 0 0.08em;
    vertical-align: middle;
    border-radius: 0;
  }

  .native-comment-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-top: 20px;
    padding-top: 16px;
    border-top: 1px solid var(--comment-border);
  }

  .native-comment-replies {
    display: grid;
    gap: 0;
    margin-top: 16px;
    margin-left: 30px;
    padding-left: 24px;
    border-left: 1px solid var(--comment-border);
  }

  .native-comment-replies[hidden] {
    display: none;
  }

  .native-comment-toggle-replies {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    min-height: 30px;
    padding: 6px 10px;
    border: none;
    border-radius: 6px;
    background: transparent;
    color: var(--comment-muted);
    font: inherit;
    font-size: 0.84rem;
    font-weight: 600;
    cursor: pointer;
  }

  .native-comment-reply-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-left: auto;
    min-height: 30px;
    padding: 6px 10px;
    border: none;
    border-radius: 6px;
    background: transparent;
    color: var(--comment-muted);
    font-size: 0.84rem;
    font-weight: 600;
  }

  .native-comment-toggle-replies:hover,
  .native-comment-reply-btn:hover {
    color: var(--comment-text);
    background: #f3f4f6;
  }

  .native-comment-toggle-replies:active,
  .native-comment-reply-btn:active,
  .native-comments-actions button:active,
  .native-comments-load-more:active {
    transform: scale(0.96);
  }

  .native-comment-toggle-replies svg,
  .native-comment-reply-btn svg {
    width: 14px;
    height: 14px;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2;
    transition: transform 0.2s ease;
  }

  .native-comment-toggle-replies.is-open svg {
    transform: rotate(180deg);
  }

  .native-comments-load-more {
    justify-self: center;
    margin-top: 4px;
  }

  @media (max-width: 768px) {
    .native-comments-fields {
      grid-template-columns: 1fr;
    }

    .native-comments-fields label + label {
      border-left: none;
      border-top: 1px solid rgba(142, 175, 156, 0.14);
    }

    .native-comments-actions {
      align-items: flex-start;
      flex-direction: column;
      gap: 10px;
    }

    .native-comments-actions button {
      width: 100%;
    }

    .native-comment {
      padding: 18px;
    }

    .native-comment-avatar {
      width: 44px;
      height: 44px;
    }

    .native-comment-replies {
      margin-left: 12px;
      padding-left: 14px;
    }
  }
</style>

<script>
  const AUTHOR_KEY = 'native-comment-author';

  function escapeHtml(value) {
    return String(value || '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#039;');
  }

  function formatDate(value) {
    try {
      const date = new Date(value);
      const now = new Date();
      const month = date.getMonth() + 1;
      const day = date.getDate();
      const hour = String(date.getHours()).padStart(2, '0');
      const minute = String(date.getMinutes()).padStart(2, '0');
      const year = date.getFullYear() === now.getFullYear() ? '' : `${date.getFullYear()}.`;
      return `${year}${month}.${day} ${hour}:${minute}`;
    } catch {
      return value;
    }
  }

  function getInitial(nick) {
    const clean = String(nick || '访客').trim();
    return clean.slice(0, 1).toUpperCase();
  }

  function escapeSvgText(value) {
    return String(value || '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;');
  }

  function hashString(value) {
    let hash = 0;
    const text = String(value || 'visitor');
    for (let index = 0; index < text.length; index += 1) {
      hash = (hash << 5) - hash + text.charCodeAt(index);
      hash |= 0;
    }
    return Math.abs(hash);
  }

  function fallbackAvatarUrl(comment) {
    const seed = `${comment.id || ''}:${comment.nick || ''}`;
    const palettes = [
      ['#69b38f', '#456f86'],
      ['#d59f62', '#8d6a9f'],
      ['#7a9ecf', '#4f6f9d'],
      ['#c77f8a', '#6f8b65'],
      ['#8aa978', '#3f7f7a'],
    ];
    const [start, end] = palettes[hashString(seed) % palettes.length];
    const initial = escapeSvgText(getInitial(comment.nick));
    const svg = `
      <svg xmlns="http://www.w3.org/2000/svg" width="96" height="96" viewBox="0 0 96 96">
        <defs>
          <linearGradient id="g" x1="0" x2="1" y1="0" y2="1">
            <stop offset="0%" stop-color="${start}" />
            <stop offset="100%" stop-color="${end}" />
          </linearGradient>
        </defs>
        <rect width="96" height="96" rx="48" fill="url(#g)" />
        <text x="50%" y="52%" fill="#fff" font-size="40" font-family="Arial, sans-serif" font-weight="700" text-anchor="middle" dominant-baseline="middle">${initial}</text>
      </svg>
    `;
    return `data:image/svg+xml;charset=UTF-8,${encodeURIComponent(svg)}`;
  }

  function normalizePath(pathname) {
    if (pathname !== '/' && !pathname.endsWith('/')) {
      return `${pathname}/`;
    }
    return pathname;
  }

  function getAuthor() {
    try {
      return JSON.parse(localStorage.getItem(AUTHOR_KEY) || '{}');
    } catch {
      return {};
    }
  }

  function chevronIcon() {
    return '<svg viewBox="0 0 24 24" aria-hidden="true"><polyline points="6 9 12 15 18 9"></polyline></svg>';
  }

  function replyIcon() {
    return '<svg viewBox="0 0 24 24" aria-hidden="true"><polyline points="9 14 4 9 9 4"></polyline><path d="M20 20v-7a4 4 0 0 0-4-4H4"></path></svg>';
  }

  function replyToggleText(count, expanded = false) {
    return `<span>${expanded ? '收起回复' : '展开回复'} (${count})</span>${chevronIcon()}`;
  }

  function renderAvatar(comment, author) {
    const fallback = fallbackAvatarUrl(comment);
    const src = comment.avatarUrl || fallback;
    return `
      <img
        src="${escapeHtml(src)}"
        alt="${author} 的头像"
        loading="lazy"
        referrerpolicy="no-referrer"
        data-fallback-avatar="${escapeHtml(fallback)}"
      />
    `;
  }

  function saveAuthor(formData) {
    const author = {
      nick: formData.get('nick') || '',
      mail: formData.get('mail') || '',
      link: formData.get('link') || '',
    };
    localStorage.setItem(AUTHOR_KEY, JSON.stringify(author));
  }

  function renderComment(comment, isReply = false) {
    const author = escapeHtml(comment.nick);
    const authorContent = comment.link
      ? `<a class="native-comment-author" href="${escapeHtml(comment.link)}" target="_blank" rel="noopener noreferrer">${author}</a>`
      : `<span class="native-comment-author">${author}</span>`;
    const replyCount = (comment.replies || []).length;
    const toggleButton = !isReply && replyCount > 0
      ? `<button type="button" class="native-comment-toggle-replies is-open" data-toggle-replies data-reply-count="${replyCount}">${replyToggleText(replyCount, true)}</button>`
      : '';
    const replyButton = isReply
      ? ''
      : `<button type="button" class="native-comment-reply-btn" data-reply-id="${escapeHtml(comment.id)}" data-reply-nick="${author}"><span>回复</span>${replyIcon()}</button>`;
    const replies = (comment.replies || []).map((reply) => renderComment(reply, true)).join('');
    const avatar = renderAvatar(comment, author);

    return `
      <article class="native-comment${isReply ? ' is-reply' : ''}">
        <div class="native-comment-header">
          <div class="native-comment-avatar">${avatar}</div>
          <div class="native-comment-meta">
            <div class="native-comment-author-line">
              ${authorContent}
            </div>
            <div class="native-comment-detail">
              <time class="native-comment-time">${escapeHtml(formatDate(comment.createdAt))}</time>
            </div>
          </div>
        </div>
        <div class="native-comment-body">${comment.contentHtml || ''}</div>
        ${replyButton ? `<div class="native-comment-foot">${toggleButton || '<span></span>'}${replyButton}</div>` : ''}
        ${!isReply && replies ? `<div class="native-comment-replies">${replies}</div>` : ''}
      </article>
    `;
  }

  function bindAvatarFallbacks(root) {
    root.querySelectorAll('[data-fallback-avatar]').forEach((image) => {
      image.addEventListener('error', () => {
        const fallback = image.getAttribute('data-fallback-avatar');
        if (fallback && image.getAttribute('src') !== fallback) {
          image.setAttribute('src', fallback);
        }
      }, { once: true });
    });
  }

  document.querySelectorAll('[data-native-comments]').forEach((root) => {
    const statusEl = root.querySelector('[data-comments-status]');
    const form = root.querySelector('[data-comment-form]');
    const listEl = root.querySelector('[data-comments-list]');
    const loadMoreBtn = root.querySelector('[data-load-more]');
    const totalEl = root.querySelector('[data-comments-total]');
    const countEl = root.querySelector('[data-comment-count]');
    const replyingEl = root.querySelector('[data-replying]');
    const replyingText = root.querySelector('[data-replying-text]');
    const cancelReplyBtn = root.querySelector('[data-cancel-reply]');
    const pageSize = Number(root.getAttribute('data-page-size') || '10');
    const state = {
      path: normalizePath(window.location.pathname),
      page: 1,
      hasMore: false,
      loading: false,
      total: 0,
      comments: [],
    };

    function setStatus(message, type = 'info') {
      if (!statusEl) return;
      statusEl.textContent = message;
      statusEl.classList.toggle('is-ok', type === 'ok');
    }

    function resetStartedAt() {
      const startedAt = form?.querySelector('[name="startedAt"]');
      if (startedAt) startedAt.value = String(Date.now());
    }

    function setReplyTarget(id, nick) {
      const parentInput = form?.querySelector('[name="parentId"]');
      if (parentInput) parentInput.value = id || '';
      if (replyingEl && replyingText) {
        if (id) {
          replyingText.textContent = `正在回复 ${nick}`;
          replyingEl.hidden = false;
        } else {
          replyingText.textContent = '';
          replyingEl.hidden = true;
        }
      }
      form?.querySelector('[name="content"]')?.focus();
    }

    function render() {
      if (!listEl) return;
      if (!state.comments.length) {
        listEl.innerHTML = '<div class="native-comments-empty">还没有评论，来留下第一句话吧。</div>';
      } else {
        listEl.innerHTML = state.comments.map((comment) => renderComment(comment)).join('');
      }
      bindAvatarFallbacks(root);

      root.querySelectorAll('[data-reply-id]').forEach((button) => {
        button.addEventListener('click', () => {
          setReplyTarget(button.getAttribute('data-reply-id'), button.getAttribute('data-reply-nick'));
        });
      });

      if (loadMoreBtn) {
        loadMoreBtn.hidden = !state.hasMore;
        loadMoreBtn.disabled = state.loading;
      }

      if (totalEl) {
        totalEl.textContent = `(${state.total})`;
      }

      root.querySelectorAll('[data-toggle-replies]').forEach((button) => {
        button.addEventListener('click', () => {
          const card = button.closest('.native-comment');
          const replies = card?.querySelector('.native-comment-replies');
          const count = button.getAttribute('data-reply-count') || '0';
          if (!replies) return;
          replies.hidden = !replies.hidden;
          button.classList.toggle('is-open', !replies.hidden);
          button.innerHTML = replyToggleText(count, !replies.hidden);
        });
      });
    }

    async function fetchComments(reset = false) {
      if (state.loading) return;
      state.loading = true;
      if (reset) state.page = 1;
      setStatus('评论区加载中...');
      render();

      try {
        const params = new URLSearchParams({
          path: state.path,
          page: String(state.page),
          pageSize: String(pageSize),
        });
        const response = await fetch(`/api/comments?${params.toString()}`);
        const payload = await response.json();
        if (!response.ok || !payload.ok) {
          throw new Error(payload.error || '评论加载失败。');
        }

        state.comments = reset
          ? payload.data.comments
          : [...state.comments, ...payload.data.comments];
        state.total = payload.data.total;
        state.hasMore = payload.data.hasMore;
        setStatus('评论区已加载', 'ok');
      } catch (error) {
        setStatus(error instanceof Error ? error.message : '评论加载失败。');
      } finally {
        state.loading = false;
        render();
      }
    }

    const author = getAuthor();
    if (form) {
      form.querySelector('[name="nick"]').value = author.nick || '';
      form.querySelector('[name="mail"]').value = author.mail || '';
      form.querySelector('[name="link"]').value = author.link || '';
      form.querySelector('[name="nick"]').placeholder = '匿名访客';
      form.querySelector('[name="mail"]').placeholder = 'name@example.com';
      form.querySelector('[name="content"]').placeholder = '还在等什么？来都来了，键盘敲起。';
      resetStartedAt();

      const textarea = form.querySelector('[name="content"]');
      const updateCount = () => {
        if (countEl && textarea) countEl.textContent = String(textarea.value.length);
      };
      textarea?.addEventListener('input', updateCount);
      updateCount();

      form.addEventListener('submit', async (event) => {
        event.preventDefault();
        const submitBtn = form.querySelector('[type="submit"]');
        const formData = new FormData(form);
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<span>发送中...</span>';
        setStatus('正在发送评论...');

        try {
          const response = await fetch('/api/comments', {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify({
              path: state.path,
              parentId: formData.get('parentId') || null,
              nick: formData.get('nick'),
              mail: formData.get('mail'),
              link: formData.get('link'),
              content: formData.get('content'),
              honeyPot: formData.get('honeyPot'),
              startedAt: Number(formData.get('startedAt')),
            }),
          });
          const payload = await response.json();
          if (!response.ok || !payload.ok) {
            throw new Error(payload.error || '评论发送失败。');
          }

          saveAuthor(formData);
          form.querySelector('[name="content"]').value = '';
          updateCount();
          setReplyTarget('', '');
          resetStartedAt();
          state.page = 1;
          await fetchComments(true);
          setStatus('评论已发布', 'ok');
        } catch (error) {
          setStatus(error instanceof Error ? error.message : '评论发送失败。');
        } finally {
          submitBtn.disabled = false;
          submitBtn.innerHTML = '<span>提交留言</span><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M21 3 10 14"></path><path d="m21 3-7 18-4-7-7-4 18-7Z"></path></svg>';
        }
      });
    }

    cancelReplyBtn?.addEventListener('click', () => setReplyTarget('', ''));
    loadMoreBtn?.addEventListener('click', async () => {
      if (!state.hasMore) return;
      state.page += 1;
      await fetchComments(false);
    });

    fetchComments(true);
  });
</script>
