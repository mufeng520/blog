---

import { toolRoutes } from '../lib/tool-routes';
import type { ToolShellConfig } from '../lib/tool-shells';

type Props = ToolShellConfig;

const {
  title,
  description,
  toolName,
  toolType = 'AI 工具',
  toolsHref = toolRoutes.index,
  accent = '#4d9273',
  iconHref = '/favicon.ico',
  appleTouchIconHref,
  lang = 'zh',
  bodyClass = '',
  fontLinks = [],
  tailwindConfig,
  toolGlobalStyle,
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href={iconHref} />
    {appleTouchIconHref ? <link rel="apple-touch-icon" href={appleTouchIconHref} /> : null}
    {fontLinks.map((href) => <link rel="stylesheet" href={href} />)}
    {tailwindConfig ? <script is:inline set:html={tailwindConfig} /> : null}
    <script is:inline src="https://cdn.tailwindcss.com"></script>
    {toolGlobalStyle ? <style is:global set:html={toolGlobalStyle} /> : null}
    <style is:global>
      .mufeng-tool-bar {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        min-width: 0;
        padding: 5px 10px 5px 5px;
        border-radius: 999px;
        background: color-mix(in srgb, var(--mufeng-tool-accent, #4d9273) 7%, #fff);
        border: 1px solid color-mix(in srgb, var(--mufeng-tool-accent, #4d9273) 18%, transparent);
        box-shadow: 0 8px 24px rgba(31, 41, 35, 0.08);
        backdrop-filter: blur(14px);
        font-family: "Outfit", "PingFang SC", "Microsoft YaHei", sans-serif;
        font-size: 0.76rem;
        font-weight: 500;
        color: #6c7f75;
        line-height: 1;
        max-width: calc(100% - 32px);
        overflow: hidden;
        transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
      }

      .mufeng-tool-bar:hover {
        border-color: color-mix(in srgb, var(--mufeng-tool-accent, #4d9273) 30%, transparent);
        box-shadow: 0 10px 28px rgba(31, 41, 35, 0.12);
      }

      .mufeng-tool-bar--inline {
        max-width: min(58vw, 560px);
        box-shadow: none;
        background: color-mix(in srgb, var(--mufeng-tool-accent, #4d9273) 6%, #fff);
      }

      .mufeng-tool-bar__home {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        min-width: 0;
        padding: 4px 9px 4px 4px;
        border-radius: 999px;
        color: #24332d;
        background: rgba(255, 255, 255, 0.72);
        text-decoration: none;
        font-weight: 600;
        transition: background 0.2s ease, color 0.2s ease;
      }

      .mufeng-tool-bar__home:hover {
        color: var(--mufeng-tool-accent, #4d9273);
        background: rgba(255, 255, 255, 0.95);
      }

      .mufeng-tool-bar__home img {
        border-radius: 6px;
      }

      .mufeng-tool-bar__sep {
        flex: 0 0 auto;
        color: color-mix(in srgb, var(--mufeng-tool-accent, #4d9273) 42%, #8a958f);
      }

      .mufeng-tool-bar__crumb {
        color: var(--mufeng-tool-accent, #4d9273);
        text-decoration: none;
        padding: 5px 7px;
        border-radius: 999px;
        transition: background 0.2s ease, color 0.2s ease;
        white-space: nowrap;
      }

      .mufeng-tool-bar__crumb:hover {
        background: color-mix(in srgb, var(--mufeng-tool-accent, #4d9273) 12%, transparent);
        color: color-mix(in srgb, var(--mufeng-tool-accent, #4d9273) 72%, #1f2933);
      }

      .mufeng-tool-bar__title {
        color: #24332d;
        font-weight: 700;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 220px;
      }

      .mufeng-tool-bar__type {
        flex: 0 0 auto;
        margin-left: 2px;
        padding: 4px 8px;
        border-radius: 999px;
        background: var(--mufeng-tool-accent, #4d9273);
        color: #fff;
        font-size: 0.68rem;
        font-weight: 600;
        letter-spacing: 0;
      }

      @media (max-width: 640px) {
        .mufeng-tool-bar {
          font-size: 0.72rem;
          max-width: calc(100vw - 24px);
        }
        .mufeng-tool-bar__title {
          max-width: 120px;
        }
        .mufeng-tool-bar__type {
          display: none;
        }
      }
    </style>
  </head>
  <body class={bodyClass}>

    <slot />
  </body>
</html>
