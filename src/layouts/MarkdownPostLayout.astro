---
import BaseLayout from './BaseLayout.astro';
import { calculateReadingTime } from '../components/lib/reading-time';

const { frontmatter, rawContent } = Astro.props as { frontmatter: Record<string, unknown>; rawContent?: (() => string) | string };
const title = frontmatter.title || '文章';

// 优先使用 rawContent（Markdown 原始内容），否则在客户端计算
const rawMarkdown = rawContent ? (typeof rawContent === 'function' ? rawContent() : rawContent) : '';
const readingTimeMinutes = rawMarkdown ? calculateReadingTime(rawMarkdown) : null;
---
<BaseLayout title={`${title} - 木风`}>
  <style>
    /* ========================================
       文章页面布局样式
       ======================================== */

    /* 文章页面主容器 - 左侧目录 + 右侧文章内容 */
    .post-wrapper {
      display: flex;
      max-width: 1160px;
      margin: 0 auto;
      gap: 24px;
      padding: 0;
      position: relative;
    }

    /* 文章内容容器 */
    .post-container {
      flex: 1;
      max-width: 860px;
      padding: 40px 34px;
      background: rgba(255, 255, 255, 0.8);
      border-radius: 30px;
      box-shadow: 0 24px 56px rgba(89, 124, 106, 0.08);
      border: 1px solid rgba(142, 175, 156, 0.18);
      margin-bottom: 24px;
      backdrop-filter: blur(18px);
    }

    /* ========================================
       目录侧边栏样式
       ======================================== */

    /* 目录侧边栏容器 */
    .toc-sidebar {
      width: 240px;
      position: sticky;
      top: 18px;
      max-height: calc(100vh - 36px);
      overflow-y: auto;
      padding: 18px 16px;
      background: rgba(255, 255, 255, 0.74);
      border-radius: 24px;
      box-shadow: 0 20px 44px rgba(89, 124, 106, 0.08);
      border: 1px solid rgba(142, 175, 156, 0.18);
      align-self: flex-start;
      backdrop-filter: blur(18px);
    }

    /* 目录标题 */
    .toc-title {
      font-size: 0.98rem;
      font-weight: 700;
      color: #24332d;
      margin-bottom: 14px;
      padding-bottom: 10px;
      border-bottom: 1px solid rgba(142, 175, 156, 0.18);
      display: flex;
      align-items: center;
      gap: 8px;
      letter-spacing: 0.04em;
    }

    /* 目录列表容器 */
    .toc-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    /* 目录项 */
    .toc-item {
      margin-bottom: 3px;
      position: relative;
    }
    /* ========================================
       目录链接样式
       ======================================== */

    /* 目录链接基础样式 - 使用多选择器覆盖浏览器默认样式 */
    :global(.toc-link){
      display: block !important;
      padding: 8px 14px;
      color: #6c7f75 !important;
      text-decoration: none !important;
      border-radius: 14px;
      transition: all 0.25s ease;
      font-size: 0.88rem;
      line-height: 1.5;
      position: relative;
      border-left: 3px solid transparent;
      margin: 3px 0;
      background-color: transparent;
      font-weight: 500;
    }

    /* 目录链接悬停效果 */
    :global(.toc-link):hover{
      background-color: rgba(105, 179, 143, 0.1);
      border-left-color: #69b38f;
      color: #4d9273 !important;
      transform: translateX(2px);
      box-shadow: none;
    }

    /* 目录链接点击效果 */
    :global(.toc-link):active{
      background-color: #e9ecef;
      transform: translateX(2px);
      transition: all 0.1s;
    }

    /* 目录链接激活状态 - 当前章节 */
    :global(.toc-link).active{
      border-left-color: #69b38f;
      background-color: rgba(105, 179, 143, 0.14);
      color: #4d9273 !important;
      font-weight: 500;
    }

    /* 响应式媒体查询 - 大屏幕 */
    @media (min-width: 768px) { 
    }

    /* 目录链接装饰点 - 悬停时显示 */
    .toc-link::before {
      content: '';
      position: absolute;
      left: 0;
      top: 50%;
      transform: translateY(-50%);
      width: 4px;
      height: 4px;
      border-radius: 50%;
      background: #d1d5da;
      opacity: 0;
      transition: all 0.3s ease;
    }

    /* 目录链接悬停效果 - 渐变背景 */
    :global(.toc-link):hover {
      background: linear-gradient(90deg, rgba(0, 168, 232, 0.08) 0%, transparent 100%);
      color: #00a8e8;
      transform: translateX(4px);
      border-left-color: #00a8e8;
    }

    /* 目录链接悬停时显示装饰点 */
    .toc-link:hover::before {
      opacity: 1;
      background: #00a8e8;
    }

    /* 目录链接激活状态 - 渐变背景和阴影 */
    .toc-link.active {
      background: linear-gradient(90deg, rgba(0, 168, 232, 0.15) 0%, rgba(0, 168, 232, 0.05) 100%);
      color: #00a8e8;
      font-weight: 600;
      border-left: 3px solid #00a8e8;
      padding-left: 11px;
      box-shadow: 0 2px 8px rgba(0, 168, 232, 0.2);
      transform: translateX(2px);
    }

    /* 目录链接激活时显示装饰点 */
    :global(.toc-link.active::before) {
      opacity: 1;
      background: #00a8e8;
      width: 6px;
      height: 6px;
    } 


    /* ========================================
       目录折叠功能样式
       ======================================== */

    /* 目录折叠样式 - 默认折叠状态 */
    :global(.toc-item-h1 > .toc-list) {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s ease-out;
    }

    /* 目录展开状态 */
    :global(.toc-item-h1.expanded > .toc-list) {
      max-height: 500px;
      transition: max-height 0.5s ease-in;
    }

    /* 箭头指示器 - 一级标题右侧 */
    :global(.toc-item-h1 > .toc-link) {
      position: relative;
      padding-right: 24px;
    }

    /* 箭头指示器样式 */
    :global(.toc-item-h1 > .toc-link::after) {
      content: '▶';
      position: absolute;
      right: 8px;
      top: 50%;
      transform: translateY(-50%) rotate(0deg);
      transition: transform 0.3s ease;
      font-size: 0.7rem;
      color: #adb5bd;
    }

    /* 展开时箭头旋转 */
    :global(.toc-item-h1.expanded > .toc-link::after) {
      transform: translateY(-50%) rotate(90deg);
    }

    /* 目录为空时的提示样式 */
    .toc-empty {
      color: #868e96;
      font-size: 0.85rem;
      text-align: center;
      padding: 30px 16px;
      border-radius: 6px;
      background: #ffffff;
      margin-top: 16px;
    }

    /* ========================================
       目录滚动条样式
       ======================================== */

    /* 滚动条宽度 */
    .toc-sidebar::-webkit-scrollbar {
      width: 6px;
    }

    /* 滚动条轨道 */
    .toc-sidebar::-webkit-scrollbar-track {
      background: #f1f3f5;
      border-radius: 3px;
      margin: 8px 0;
    }

    /* 滚动条滑块 */
    .toc-sidebar::-webkit-scrollbar-thumb {
      background: #ced4da;
      border-radius: 3px;
      transition: background 0.3s ease;
    }

    /* 滚动条滑块悬停效果 */
    .toc-sidebar::-webkit-scrollbar-thumb:hover {
      background: #adb5bd;
    }

    /* ========================================
       文章头部样式
       ======================================== */

    /* 文章头部容器 */
    .post-header {
      text-align: center;
      margin-bottom: 34px;
      padding-bottom: 24px;
      border-bottom: 1px solid rgba(142, 175, 156, 0.18);
    }

    /* 文章标题 */
    .post-title {
      font-family: "Noto Serif SC", serif;
      font-size: clamp(2rem, 4vw, 2.9rem);
      font-weight: 700;
      color: #24332d;
      margin-bottom: 14px;
      line-height: 1.3;
      letter-spacing: 0.02em;
    }

    /* 文章元信息（分类、日期、阅读时间） */
    .post-meta {
      color: #6c7f75;
      font-size: 0.9rem;
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 14px;
      flex-wrap: wrap;
    }

    /* 文章分类标签 */
    .post-category {
      display: flex;
      align-items: center;
      gap: 5px;
      padding: 7px 14px;
      background: rgba(105, 179, 143, 0.14);
      color: #4d9273;
      border-radius: 999px;
      font-size: 0.8rem;
      font-weight: 500;
    }

    /* 文章日期和阅读时间 */
    .post-date,
    .post-reading-time {
      display: flex;
      align-items: center;
      gap: 5px;
    }

    /* ========================================
       文章内容样式
       ======================================== */

    /* 文章内容容器 */
    .post-content {
      color: #31423a;
      line-height: 1.9;
      font-size: 1.02rem;
    }

    /* 文章内一级标题样式 */
    .post-content :global(h1) {
      font-size: 1.95rem;
      font-weight: 700;
      color: #24332d;
      margin-top: 42px;
      margin-bottom: 18px;
      padding-bottom: 10px;
      border-bottom: 1px solid rgba(105, 179, 143, 0.2);
    }

    /* 文章内二级标题样式 */
    .post-content :global(h2) {
      font-size: 1.55rem;
      font-weight: 700;
      color: #24332d;
      margin-top: 34px;
      margin-bottom: 16px;
      padding-bottom: 0;
      border-bottom: none;
    }

    /* 文章内三级标题样式 */
    .post-content :global(h3) {
      font-size: 1.3rem;
      font-weight: 600;
      color: #333;
      margin-top: 30px;
      margin-bottom: 15px;
    }

    /* 文章内四级标题样式 */
    .post-content :global(h4) {
      font-size: 1.1rem;
      font-weight: 600;
      color: #333;
      margin-top: 25px;
      margin-bottom: 12px;
    }

    .post-content :global(h5),
    .post-content :global(h6) {
      font-size: 1rem;
      font-weight: 600;
      color: #333;
      margin-top: 20px;
      margin-bottom: 10px;
    }

    /* 段落样式 */
    .post-content :global(p) {
      margin-bottom: 16px;
      text-align: left;
    }

    /* 链接样式 */
    .post-content :global(a) {
      color: #4d9273;
      text-decoration: none;
      border-bottom: 1px solid rgba(105, 179, 143, 0.32);
      transition: all 0.3s ease;
    }

    .post-content :global(a:hover) {
      color: #3c7158;
      border-bottom-color: #3c7158;
    }

    /* 列表样式 */
    .post-content :global(ul),
    .post-content :global(ol) {
      margin-bottom: 16px;
      padding-left: 25px;
    }

    .post-content :global(li) {
      margin-bottom: 8px;
      line-height: 1.6;
    }

    .post-content :global(ul li) {
      list-style-type: disc;
      position: static;
    }

    .post-content :global(ul li::before) {
      display: none;
    }

    /* 引用样式 */
    .post-content :global(blockquote) {
      border-left: 4px solid #8ec7aa;
      background: rgba(142, 199, 170, 0.12);
      padding: 18px 20px;
      margin: 20px 0;
      border-radius: 0 16px 16px 0;
      color: #51655b;
    }

    /* 过期通知样式 */
    .post-expire {
      background: #f8f8f8;
      border: 1px solid #eee;
      border-radius: 8px;
      padding: 12px 16px;
      margin-bottom: 20px;
      font-size: 0.9rem;
      color: #666;
    }

    /* 许可证信息样式 */
    .post-license {
      background: #f8f8f8;
      border: 1px solid #eee;
      border-radius: 8px;
      padding: 20px;
      margin-top: 40px;
      font-size: 0.9rem;
      color: #666;
    }

    /* 标签样式 */
    .post-tags {
      margin-top: 30px;
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    .post-tag {
      display: inline-block;
      padding: 6px 14px;
      background: #f0f0f0;
      color: #666;
      border-radius: 20px;
      font-size: 0.85rem;
      font-weight: 500;
      text-decoration: none;
      transition: all 0.3s ease;
    }

    .post-tag:hover {
      background: #e0e0e0;
      color: #333;
    }

    /* 代码块样式 - 参考第一张图的浅色风格 */
    .post-content :global(pre) {
      background: #f3f8f4;
      border: 1px solid rgba(142, 175, 156, 0.2);
      border-radius: 18px;
      padding: 18px 20px;
      overflow-x: auto;
      margin: 25px 0;
      font-size: 0.95rem;
      line-height: 1.6;
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.7);
    }

    .post-content :global(code) {
      background: rgba(105, 179, 143, 0.12);
      color: #416d58;
      padding: 3px 8px;
      border-radius: 6px;
      font-size: 0.9em;
      font-family: 'Consolas', 'Monaco', 'Courier New', monospace;
    }

    .post-content :global(pre code) {
      background: transparent;
      color: #333;
      padding: 0;
      border-radius: 0;
      font-size: inherit;
    }

    /* 参考figure代码块样式 */
    .post-content :global(figure.highlight) {
      margin: 25px 0;
      border-radius: 18px;
      overflow: hidden;
      box-shadow: 0 18px 36px rgba(89, 124, 106, 0.08);
    }

    .post-content :global(figure.highlight table) {
      width: 100%;
      border-collapse: collapse;
      margin: 0;
      background: #f3f8f4;
    }

    .post-content :global(figure.highlight tbody) {
      margin: 0;
      padding: 0;
    }

    .post-content :global(figure.highlight tr) {
      margin: 0;
      padding: 0;
    }

    .post-content :global(figure.highlight td.code) {
      padding: 0;
      border: none;
    }

    .post-content :global(figure.highlight pre) {
      margin: 0;
      border: none;
      border-radius: 0;
      box-shadow: none;
      background: #f3f8f4;
    }

    /* 代码高亮样式 - 参考第一张图 */
    .post-content :global(.punctuation) {
      color: #999;
    }

    .post-content :global(.attr) {
      color: #d17a22;
    }

    .post-content :global(.string) {
      color: #2c70b3;
    }

    /* 浅色主题代码高亮 */
    .post-content :global(.astro-code) {
      background: #f3f8f4 !important;
      color: #333 !important;
    }

    .post-content :global(.astro-code github-dark) {
      background: #f3f8f4 !important;
      color: #333 !important;
    }

    /* 引用样式 */
    .post-content :global(blockquote) {
      border-left: 4px solid #00a8e8;
      background: rgba(0, 168, 232, 0.06);
      padding: 20px 25px;
      margin: 25px 0;
      border-radius: 0 12px 12px 0;
      font-style: italic;
      color: #555;
    }

    .post-content :global(blockquote p) {
      margin-bottom: 0;
    }

    /* 图片样式 */
    .post-content :global(img) {
      max-width: 100%;
      height: auto;
      border-radius: 18px;
      box-shadow: 0 18px 36px rgba(89, 124, 106, 0.08);
      margin: 30px auto;
      display: block;
    }

    /* 表格样式 */
    .post-content :global(table) {
      width: 100%;
      border-collapse: collapse;
      margin: 25px 0;
      background: #fff;
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
      border: 1px solid #eee;
    }

    .post-content :global(th) {
      background: rgba(0, 168, 232, 0.1);
      padding: 12px 15px;
      text-align: left;
      font-weight: 600;
      color: #333;
    }

    .post-content :global(td) {
      padding: 12px 15px;
      border-top: 1px solid #eee;
    }

    .post-content :global(tr:hover) {
      background: rgba(0, 168, 232, 0.04);
    }

    /* 水平分割线 */
    .post-content :global(hr) {
      border: none;
      border-top: 2px solid #eee;
      margin: 40px 0;
      border-radius: 2px;
    }

    /* 强调样式 */
    .post-content :global(strong) {
      color: #333;
      font-weight: 600;
    }

    .post-content :global(em) {
      color: #0077b6;
      font-style: italic;
    }

    /* 数学公式样式（KaTeX/MathJax） */
    .post-content :global(.math),
    .post-content :global(.katex) {
      font-size: 1.1em;
    }

    @media (max-width: 1200px) {
      .toc-sidebar {
        display: none;
      }
    }

    @media (max-width: 768px) {
      .post-container {
        padding: 28px 20px;
        margin: 12px 0;
        border-radius: 24px;
      }

      .post-title {
        font-size: 2rem;
      }

      .post-content :global(h1) {
        font-size: 1.8rem;
      }

      .post-content :global(h2) {
        font-size: 1.5rem;
      }

      .post-content :global(h3) {
        font-size: 1.3rem;
      }

      .post-content :global(pre) {
        padding: 15px;
        font-size: 0.85rem;
      }
    } 

  </style>

  <div class="post-wrapper">
    <aside class="toc-sidebar" id="toc-sidebar">
      <div class="toc-title">
        <svg class="icon" style="width: 1em;height: 1em;vertical-align: middle;fill: currentColor;overflow: hidden;" viewBox="0 0 1024 1024" version="1.1" xmlns="http://www.w3.org/2000/svg" p-id="1040">
          <path d="M841 317.6H641c-28.7 0-52-23.3-52-52V84h46v181.6c0 3.3 2.7 6 6 6h200v46z" fill="" p-id="1041"></path>
          <path d="M804 968H215c-29.2 0-53-23.8-53-53V121c0-29.2 23.8-53 53-53h41c12.7 0 23 10.3 23 23s-10.3 23-23 23h-41c-3.9 0-7 3.1-7 7v794c0 3.9 3.1 7 7 7h589c3.9 0 7-3.1 7-7V290.5L609.3 114H426c-12.7 0-23-10.3-23-23s10.3-23 23-23h192c5.6 0 11 2 15.1 5.7l216 189c5 4.4 7.9 10.7 7.9 17.3v635c0 29.2-23.8 53-53 53zM364.9 114h-39c-12.7 0-23-10.3-23-23s10.3-23 23-23h39c12.7 0 23 10.3 23 23s-10.3 23-23 23z" fill="" p-id="1042"></path>
          <path d="M308 266h36c7.7 0 14 6.3 14 14v36c0 7.7-6.3 14-14 14h-36c-7.7 0-14-6.3-14-14v-36c0-7.7 6.3-14 14-14zM423 275h101c12.7 0 23 10.3 23 23s-10.3 23-23 23H423c-12.7 0-23-10.3-23-23s10.3-23 23-23zM308 410h36c7.7 0 14 6.3 14 14v36c0 7.7-6.3 14-14 14h-36c-7.7 0-14-6.3-14-14v-36c0-7.7 6.3-14 14-14zM423 419h286c12.7 0 23 10.3 23 23s-10.3 23-23 23H423c-12.7 0-23-10.3-23-23s10.3-23 23-23z" fill="" p-id="1043"></path>
          <path d="M308 554h36c7.7 0 14 6.3 14 14v36c0 7.7-6.3 14-14 14h-36c-7.7 0-14-6.3-14-14v-36c0-7.7 6.3-14 14-14zM423 563h286c12.7 0 23 10.3 23 23s-10.3 23-23 23H423c-12.7 0-23-10.3-23-23s10.3-23 23-23z" fill="" p-id="1044"></path>
          <path d="M308 698h36c7.7 0 14 6.3 14 14v36c0 7.7-6.3 14-14 14h-36c-7.7 0-14-6.3-14-14v-36c0-7.7 6.3-14 14-14zM423 707h286c12.7 0 23 10.3 23 23s-10.3 23-23 23H423c-12.7 0-23-10.3-23-23s10.3-23 23-23z" fill="" p-id="1045"></path>
        </svg>
        <span>目录</span>
        
      </div>
      <ul class="toc-list" id="toc-list">
        <li class="toc-empty">正在加载目录...</li>
      </ul>
    </aside>

    <article class="post-container">
      <header class="post-header">
        <h1 class="post-title">{frontmatter.title}</h1>
        <div class="post-meta">
          {frontmatter.category && (
            <div class="post-category">
              <span>📂</span>
              <span>{frontmatter.category}</span>
            </div>
          )}
          {frontmatter.pubdate && (
            <div class="post-date">
              <time>{frontmatter.pubdate}</time>
            </div>
          )}
          <div class="post-reading-time" id="post-reading-time">
            {readingTimeMinutes !== null ? (
              <>
                <span>{readingTimeMinutes} 分钟阅读</span>
              </>
            ) : (
              <span class="reading-time-placeholder">⏱️ <span id="reading-time-value">--</span> 分钟阅读</span>
            )}
          </div>
        </div>
      </header>
      <div class="post-content" id="post-content">
        <slot />
      </div>
    </article>
  </div>

  <script>
    import { calculateReadingTimeFromText } from '../components/lib/reading-time';

    function updateReadingTime() {
      const content = document.getElementById('post-content');
      const readingTimeEl = document.getElementById('reading-time-value');
      if (content && readingTimeEl && readingTimeEl.textContent === '--') {
        const plainText = content.textContent || '';
        const minutes = calculateReadingTimeFromText(plainText);
        readingTimeEl.textContent = String(minutes);
      }
    }

    function generateTOC() {
      const content = document.getElementById('post-content');
      const tocList = document.getElementById('toc-list');
      
      if (!content || !tocList) return;

      // 获取所有标题
      const headings = content.querySelectorAll('h1, h2, h3, h4, h5, h6');
      
      if (headings.length === 0) {
        tocList.innerHTML = '<li class="toc-empty">暂无目录</li>';
        return;
      }

      // 清空现有内容
      tocList.innerHTML = '';

      // 为每个标题添加 ID（如果还没有）
      headings.forEach((heading, index) => {
        if (!heading.id) {
          // 生成基于文本的 ID
          const text = heading.textContent || '';
          const id = text
            .toLowerCase()
            .replace(/[^\w\u4e00-\u9fa5]+/g, '-')
            .replace(/^-|-$/g, '') || `heading-${index}`;
          heading.id = id;
        }
      });

      // 生成目录项（嵌套结构）
      const headingMap = new Map();
      let currentH1: HTMLLIElement | null = null;
      let currentH2: HTMLLIElement | null = null;
      let currentH3: HTMLLIElement | null = null;
      let currentH4: HTMLLIElement | null = null;
      let currentH5: HTMLLIElement | null = null;

      headings.forEach((heading) => {
        const level = parseInt(heading.tagName.charAt(1));
        const text = heading.textContent || '';
        const id = heading.id;

        const li = document.createElement('li');
        li.className = `toc-item toc-item-h${level}`;
        
        const a = document.createElement('a');
        a.href = `#${id}`;
        a.className = 'toc-link';
        a.textContent = text;
        
        // 平滑滚动
        a.addEventListener('click', (e) => {
          e.preventDefault();
          const target = document.getElementById(id) as HTMLElement;
          if (target) {
            const offsetTop = target.offsetTop - 80;
            window.scrollTo({
              top: offsetTop,
              behavior: 'smooth'
            });
            // 更新 URL 但不触发滚动
            history.pushState(null, '', `#${id}`);
          }
        });

        li.appendChild(a);

        // 嵌套目录结构
        if (level === 1) {
          // 创建子目录列表
          const subList = document.createElement('ul');
          subList.className = 'toc-list';
          li.appendChild(subList);
          tocList.appendChild(li);
          currentH1 = li;
          currentH2 = null;
          currentH3 = null;
          currentH4 = null;
          currentH5 = null;
        } else if (level === 2 && currentH1) {
          const subList = currentH1.querySelector('.toc-list');
          if (subList) {
            subList.appendChild(li);
            currentH2 = li;
            currentH3 = null;
            currentH4 = null;
            currentH5 = null;
          }
        } else if (level === 3 && currentH2) {
          // 为H2创建子目录列表
          let subList = currentH2.querySelector('.toc-list');
          if (!subList) {
            subList = document.createElement('ul');
            subList.className = 'toc-list';
            currentH2.appendChild(subList);
          }
          subList.appendChild(li);
          currentH3 = li;
          currentH4 = null;
          currentH5 = null;
        } else if (level === 4 && currentH3) {
          // 为H3创建子目录列表
          let subList = currentH3.querySelector('.toc-list');
          if (!subList) {
            subList = document.createElement('ul');
            subList.className = 'toc-list';
            currentH3.appendChild(subList);
          }
          subList.appendChild(li);
          currentH4 = li;
          currentH5 = null;
        } else if (level === 5 && currentH4) {
          // 为H4创建子目录列表
          let subList = currentH4.querySelector('.toc-list');
          if (!subList) {
            subList = document.createElement('ul');
            subList.className = 'toc-list';
            currentH4.appendChild(subList);
          }
          subList.appendChild(li);
          currentH5 = li;
        } else if (level === 6 && currentH5) {

          // 为H5创建子目录列表
          let subList = currentH5.querySelector('.toc-list');
          if (!subList) {
            subList = document.createElement('ul');
            subList.className = 'toc-list';
            currentH5.appendChild(subList);
          }
          subList.appendChild(li);
        }

        // 存储标题映射
        headingMap.set(id, li);
      });

      // 添加H1点击事件，实现折叠/展开
      document.querySelectorAll('.toc-item-h1 > .toc-link').forEach((link) => {
        link.addEventListener('click', function(e) {
          const parent = (e.currentTarget as HTMLElement).closest('.toc-item-h1');
          if (parent) {
            parent.classList.toggle('expanded');
          }
        });
      });

      // 监听滚动，高亮当前章节并展开对应目录
      let currentActive = '';
      const observerOptions = {
        rootMargin: '-80px 0px -80% 0px',
        threshold: 0
      };

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const id = entry.target.id;
            if (id && id !== currentActive) {
              // 移除旧的 active 类
              document.querySelectorAll('.toc-link.active').forEach((link) => {
                link.classList.remove('active');
              });
              
              // 添加新的 active 类
              const activeLink = document.querySelector(`.toc-link[href="#${id}"]`);
              if (activeLink) {
                activeLink.classList.add('active');
                currentActive = id;
                
                // 展开所有父级目录
                let current = activeLink.closest('.toc-item');
                while (current) {
                  if (current.classList.contains('toc-item-h1')) {
                    current.classList.add('expanded');
                  }
                  current = current.parentElement?.closest('.toc-item') ?? null;
                }
                
                // 滚动到可见区域（如果需要）
                const sidebar = document.getElementById('toc-sidebar') as HTMLElement;
                if (sidebar && (activeLink as HTMLElement).offsetTop > sidebar.scrollTop + sidebar.clientHeight - 100) {
                  sidebar.scrollTo({
                    top: (activeLink as HTMLElement).offsetTop - 100,
                    behavior: 'smooth'
                  });
                }
              }
            }
          }
        });
      }, observerOptions);

      // 观察所有标题
      headings.forEach((heading) => {
        observer.observe(heading);
      });

      // 处理页面加载时的 hash
      if (window.location.hash) {
        const hash = window.location.hash.substring(1);
        const target = document.getElementById(hash) as HTMLElement;
        if (target) {
          setTimeout(() => {
            const offsetTop = target.offsetTop - 80;
            window.scrollTo({
              top: offsetTop,
              behavior: 'smooth'
            });
            const activeLink = document.querySelector(`.toc-link[href="#${hash}"]`);
            if (activeLink) {
              activeLink.classList.add('active');
              
              // 展开所有父级目录
              let current = activeLink.closest('.toc-item');
              while (current) {
                if (current.classList.contains('toc-item-h1')) {
                  current.classList.add('expanded');
                }
                current = current.parentElement?.closest('.toc-item') ?? null;
              }
            }
          }, 100);
        }
      }
    }

    // 页面加载完成后生成目录并更新阅读时间
    function init() {
      generateTOC();
      updateReadingTime();
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  </script>
</BaseLayout>
