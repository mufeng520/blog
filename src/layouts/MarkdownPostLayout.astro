---
import BaseLayout from './BaseLayout.astro';
import { calculateReadingTime } from '../components/lib/reading-time';

const { frontmatter, rawContent } = Astro.props as { frontmatter: Record<string, unknown>; rawContent?: (() => string) | string };
const title = frontmatter.title || '文章';

// 优先使用 rawContent（Markdown 原始内容），否则在客户端计算
const rawMarkdown = rawContent ? (typeof rawContent === 'function' ? rawContent() : rawContent) : '';
const readingTimeMinutes = rawMarkdown ? calculateReadingTime(rawMarkdown) : null;
---
<BaseLayout title={`${title} - 木风`}>
  <style>
    .post-wrapper {
      display: flex;
      max-width: 1400px;
      margin: 0 auto;
      gap: 40px;
      padding: 0 20px;
      position: relative;
    }

    .post-container {
      flex: 1;
      max-width: 900px;
      padding: 40px 30px;
      background: #fff;
      border-radius: 24px;
      box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
      border: 1px solid #eee;
      margin-bottom: 40px;
    }

    .toc-sidebar {
      width: 260px;
      position: sticky;
      top: 80px;
      max-height: calc(100vh - 100px);
      overflow-y: auto;
      padding: 18px 16px;
      background: linear-gradient(135deg, #fafbfc 0%, #f5f6f7 100%);
      border-radius: 12px;
      box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
      border: 1px solid #e1e4e8;
      align-self: flex-start;
    }

    .toc-title {
      font-size: 1.05rem;
      font-weight: 700;
      color: #24292e;
      margin-bottom: 18px;
      padding-bottom: 12px;
      border-bottom: 2px solid #e1e4e8;
      display: flex;
      align-items: center;
      gap: 8px;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif;
      letter-spacing: 0.5px;
    }

    .toc-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .toc-item {
      margin-bottom: 3px;
      position: relative;
    }

    .toc-link {
      display: block;
      padding: 7px 12px;
      color: #586069;
      text-decoration: none;
      border-radius: 6px;
      transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
      font-size: 0.88rem;
      line-height: 1.5;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif;
      letter-spacing: 0.3px;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    .toc-link:hover {
      background: rgba(0, 168, 232, 0.08);
      color: #00a8e8;
      transform: translateX(2px);
    }

    .toc-link.active {
      background: linear-gradient(90deg, rgba(0, 168, 232, 0.12) 0%, rgba(0, 168, 232, 0.05) 100%);
      color: #00a8e8;
      font-weight: 600;
      border-left: 3px solid #00a8e8;
      padding-left: 9px;
      box-shadow: 0 2px 4px rgba(0, 168, 232, 0.15);
    }

    /* 层级样式优化 */
    .toc-item-h1 .toc-link {
      font-weight: 700;
      color: #24292e;
      padding-left: 16px;
      font-size: 0.92rem;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif;
      letter-spacing: 0.5px;
    }

    .toc-item-h2 .toc-link {
      padding-left: 28px;
      font-size: 0.88rem;
      color: #2f363d;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif;
      letter-spacing: 0.3px;
    }

    .toc-item-h3 .toc-link {
      padding-left: 40px;
      font-size: 0.85rem;
      color: #444d56;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif;
      letter-spacing: 0.2px;
    }

    .toc-item-h4 .toc-link {
      padding-left: 52px;
      font-size: 0.82rem;
      color: #586069;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif;
    }

    .toc-item-h5 .toc-link {
      padding-left: 64px;
      font-size: 0.8rem;
      color: #6a737d;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif;
    }

    .toc-item-h6 .toc-link {
      padding-left: 76px;
      font-size: 0.78rem;
      color: #959da5;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif;
    }

    /* 目录折叠样式 */
    .toc-item-h1 > .toc-list {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s ease-out;
    }

    .toc-item-h1.expanded > .toc-list {
      max-height: 500px;
      transition: max-height 0.5s ease-in;
    }

    /* 箭头指示 */
    .toc-item-h1 > .toc-link {
      position: relative;
      padding-right: 24px;
    }

    .toc-item-h1 > .toc-link::after {
      content: '▶';
      position: absolute;
      right: 8px;
      top: 50%;
      transform: translateY(-50%) rotate(0deg);
      transition: transform 0.3s ease;
      font-size: 0.7rem;
      color: #adb5bd;
    }

    .toc-item-h1.expanded > .toc-link::after {
      transform: translateY(-50%) rotate(90deg);
    }

    /* 移除默认超链接样式 */
    .toc-link {
      text-decoration: none;
      color: inherit;
      transition: all 0.2s ease;
    }

    .toc-link:hover {
      color: #00a8e8;
      background: rgba(0, 168, 232, 0.05);
    }

    .toc-link.active {
      color: #00a8e8;
      font-weight: 500;
      background: rgba(0, 168, 232, 0.08);
      border-left: 3px solid #00a8e8;
      padding-left: 13px;
    }

    .toc-empty {
      color: #868e96;
      font-size: 0.85rem;
      text-align: center;
      padding: 30px 16px;
      border-radius: 6px;
      background: #ffffff;
      margin-top: 16px;
    }

    /* 滚动条样式优化 */
    .toc-sidebar::-webkit-scrollbar {
      width: 6px;
    }

    .toc-sidebar::-webkit-scrollbar-track {
      background: #f1f3f5;
      border-radius: 3px;
      margin: 8px 0;
    }

    .toc-sidebar::-webkit-scrollbar-thumb {
      background: #ced4da;
      border-radius: 3px;
      transition: background 0.3s ease;
    }

    .toc-sidebar::-webkit-scrollbar-thumb:hover {
      background: #adb5bd;
    }

    .post-header {
      text-align: center;
      margin-bottom: 40px;
      padding-bottom: 30px;
      border-bottom: 2px solid #eee;
    }

    .post-title {
      font-size: 2.8rem;
      font-weight: 600;
      color: #333;
      margin-bottom: 15px;
      line-height: 1.3;
      letter-spacing: -0.5px;
    }

    .post-meta {
      color: #666;
      font-size: 0.95rem;
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 20px;
      flex-wrap: wrap;
    }

    .post-category {
      display: flex;
      align-items: center;
      gap: 5px;
      padding: 6px 14px;
      background: #00a8e8;
      color: #fff;
      border-radius: 20px;
      font-size: 0.85rem;
      font-weight: 500;
    }

    .post-date,
    .post-reading-time {
      display: flex;
      align-items: center;
      gap: 5px;
    }

    .post-content {
      color: #333;
      line-height: 1.8;
      font-size: 1rem;
    }

    /* 标题样式 */
    .post-content :global(h1) {
      font-size: 2rem;
      font-weight: 600;
      color: #333;
      margin-top: 40px;
      margin-bottom: 20px;
      padding-bottom: 10px;
      border-bottom: 2px solid rgba(0, 168, 232, 0.3);
    }

    .post-content :global(h2) {
      font-size: 1.6rem;
      font-weight: 600;
      color: #333;
      margin-top: 35px;
      margin-bottom: 18px;
      padding-bottom: 8px;
      border-bottom: 1px solid rgba(0, 168, 232, 0.2);
    }

    .post-content :global(h3) {
      font-size: 1.3rem;
      font-weight: 600;
      color: #333;
      margin-top: 30px;
      margin-bottom: 15px;
    }

    .post-content :global(h4) {
      font-size: 1.1rem;
      font-weight: 600;
      color: #333;
      margin-top: 25px;
      margin-bottom: 12px;
    }

    .post-content :global(h5),
    .post-content :global(h6) {
      font-size: 1rem;
      font-weight: 600;
      color: #333;
      margin-top: 20px;
      margin-bottom: 10px;
    }

    /* 段落样式 */
    .post-content :global(p) {
      margin-bottom: 16px;
      text-align: left;
    }

    /* 链接样式 */
    .post-content :global(a) {
      color: #0066cc;
      text-decoration: none;
      border-bottom: 1px solid rgba(0, 102, 204, 0.3);
      transition: all 0.3s ease;
    }

    .post-content :global(a:hover) {
      color: #004c99;
      border-bottom-color: #004c99;
    }

    /* 列表样式 */
    .post-content :global(ul),
    .post-content :global(ol) {
      margin-bottom: 16px;
      padding-left: 25px;
    }

    .post-content :global(li) {
      margin-bottom: 8px;
      line-height: 1.6;
    }

    .post-content :global(ul li) {
      list-style-type: disc;
      position: static;
    }

    .post-content :global(ul li::before) {
      display: none;
    }

    /* 引用样式 */
    .post-content :global(blockquote) {
      border-left: 4px solid #00a8e8;
      background: rgba(0, 168, 232, 0.06);
      padding: 15px 20px;
      margin: 20px 0;
      border-radius: 0 8px 8px 0;
      font-style: italic;
      color: #555;
    }

    /* 过期通知样式 */
    .post-expire {
      background: #f8f8f8;
      border: 1px solid #eee;
      border-radius: 8px;
      padding: 12px 16px;
      margin-bottom: 20px;
      font-size: 0.9rem;
      color: #666;
    }

    /* 许可证信息样式 */
    .post-license {
      background: #f8f8f8;
      border: 1px solid #eee;
      border-radius: 8px;
      padding: 20px;
      margin-top: 40px;
      font-size: 0.9rem;
      color: #666;
    }

    /* 标签样式 */
    .post-tags {
      margin-top: 30px;
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    .post-tag {
      display: inline-block;
      padding: 6px 14px;
      background: #f0f0f0;
      color: #666;
      border-radius: 20px;
      font-size: 0.85rem;
      font-weight: 500;
      text-decoration: none;
      transition: all 0.3s ease;
    }

    .post-tag:hover {
      background: #e0e0e0;
      color: #333;
    }

    /* 代码块样式 - 参考第一张图的浅色风格 */
    .post-content :global(pre) {
      background: #f8f5e6;
      border: 1px solid #e8e0c9;
      border-radius: 12px;
      padding: 20px;
      overflow-x: auto;
      margin: 25px 0;
      font-size: 0.95rem;
      line-height: 1.6;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    }

    .post-content :global(code) {
      background: rgba(0, 168, 232, 0.1);
      color: #0077b6;
      padding: 3px 8px;
      border-radius: 6px;
      font-size: 0.9em;
      font-family: 'Consolas', 'Monaco', 'Courier New', monospace;
    }

    .post-content :global(pre code) {
      background: transparent;
      color: #333;
      padding: 0;
      border-radius: 0;
      font-size: inherit;
    }

    /* 参考figure代码块样式 */
    .post-content :global(figure.highlight) {
      margin: 25px 0;
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    }

    .post-content :global(figure.highlight table) {
      width: 100%;
      border-collapse: collapse;
      margin: 0;
      background: #f8f5e6;
    }

    .post-content :global(figure.highlight tbody) {
      margin: 0;
      padding: 0;
    }

    .post-content :global(figure.highlight tr) {
      margin: 0;
      padding: 0;
    }

    .post-content :global(figure.highlight td.code) {
      padding: 0;
      border: none;
    }

    .post-content :global(figure.highlight pre) {
      margin: 0;
      border: none;
      border-radius: 0;
      box-shadow: none;
      background: #f8f5e6;
    }

    /* 代码高亮样式 - 参考第一张图 */
    .post-content :global(.punctuation) {
      color: #999;
    }

    .post-content :global(.attr) {
      color: #d17a22;
    }

    .post-content :global(.string) {
      color: #2c70b3;
    }

    /* 浅色主题代码高亮 */
    .post-content :global(.astro-code) {
      background: #f8f5e6 !important;
      color: #333 !important;
    }

    .post-content :global(.astro-code github-dark) {
      background: #f8f5e6 !important;
      color: #333 !important;
    }

    /* 引用样式 */
    .post-content :global(blockquote) {
      border-left: 4px solid #00a8e8;
      background: rgba(0, 168, 232, 0.06);
      padding: 20px 25px;
      margin: 25px 0;
      border-radius: 0 12px 12px 0;
      font-style: italic;
      color: #555;
    }

    .post-content :global(blockquote p) {
      margin-bottom: 0;
    }

    /* 图片样式 */
    .post-content :global(img) {
      max-width: 100%;
      height: auto;
      border-radius: 12px;
      box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
      margin: 30px auto;
      display: block;
    }

    /* 表格样式 */
    .post-content :global(table) {
      width: 100%;
      border-collapse: collapse;
      margin: 25px 0;
      background: #fff;
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
      border: 1px solid #eee;
    }

    .post-content :global(th) {
      background: rgba(0, 168, 232, 0.1);
      padding: 12px 15px;
      text-align: left;
      font-weight: 600;
      color: #333;
    }

    .post-content :global(td) {
      padding: 12px 15px;
      border-top: 1px solid #eee;
    }

    .post-content :global(tr:hover) {
      background: rgba(0, 168, 232, 0.04);
    }

    /* 水平分割线 */
    .post-content :global(hr) {
      border: none;
      border-top: 2px solid #eee;
      margin: 40px 0;
      border-radius: 2px;
    }

    /* 强调样式 */
    .post-content :global(strong) {
      color: #333;
      font-weight: 600;
    }

    .post-content :global(em) {
      color: #0077b6;
      font-style: italic;
    }

    /* 数学公式样式（KaTeX/MathJax） */
    .post-content :global(.math),
    .post-content :global(.katex) {
      font-size: 1.1em;
    }

    @media (max-width: 1200px) {
      .toc-sidebar {
        display: none;
      }
    }

    @media (max-width: 768px) {
      .post-wrapper {
        padding: 0 15px;
      }

      .post-container {
        padding: 30px 20px;
        margin: 20px 0;
        border-radius: 16px;
      }

      .post-title {
        font-size: 2rem;
      }

      .post-content :global(h1) {
        font-size: 1.8rem;
      }

      .post-content :global(h2) {
        font-size: 1.5rem;
      }

      .post-content :global(h3) {
        font-size: 1.3rem;
      }

      .post-content :global(pre) {
        padding: 15px;
        font-size: 0.85rem;
      }
    }
  </style>

  <div class="post-wrapper">
    <aside class="toc-sidebar" id="toc-sidebar">
      <div class="toc-title">
        <span>📑</span>
        <span>目录</span>
      </div>
      <ul class="toc-list" id="toc-list">
        <li class="toc-empty">正在加载目录...</li>
      </ul>
    </aside>

    <article class="post-container">
      <header class="post-header">
        <h1 class="post-title">{frontmatter.title}</h1>
        <div class="post-meta">
          {frontmatter.category && (
            <div class="post-category">
              <span>📂</span>
              <span>{frontmatter.category}</span>
            </div>
          )}
          {frontmatter.pubdate && (
            <div class="post-date">
              <span>📅</span>
              <time>{frontmatter.pubdate}</time>
            </div>
          )}
          <div class="post-reading-time" id="post-reading-time">
            {readingTimeMinutes !== null ? (
              <>
                <span>⏱️</span>
                <span>{readingTimeMinutes} 分钟阅读</span>
              </>
            ) : (
              <span class="reading-time-placeholder">⏱️ <span id="reading-time-value">--</span> 分钟阅读</span>
            )}
          </div>
        </div>
      </header>
      <div class="post-content" id="post-content">
        <slot />
      </div>
    </article>
  </div>

  <script>
    import { calculateReadingTimeFromText } from '../components/lib/reading-time';

    function updateReadingTime() {
      const content = document.getElementById('post-content');
      const readingTimeEl = document.getElementById('reading-time-value');
      if (content && readingTimeEl && readingTimeEl.textContent === '--') {
        const plainText = content.textContent || '';
        const minutes = calculateReadingTimeFromText(plainText);
        readingTimeEl.textContent = String(minutes);
      }
    }

    function generateTOC() {
      const content = document.getElementById('post-content');
      const tocList = document.getElementById('toc-list');
      
      if (!content || !tocList) return;

      // 获取所有标题
      const headings = content.querySelectorAll('h1, h2, h3, h4, h5, h6');
      
      if (headings.length === 0) {
        tocList.innerHTML = '<li class="toc-empty">暂无目录</li>';
        return;
      }

      // 清空现有内容
      tocList.innerHTML = '';

      // 为每个标题添加 ID（如果还没有）
      headings.forEach((heading, index) => {
        if (!heading.id) {
          // 生成基于文本的 ID
          const text = heading.textContent || '';
          const id = text
            .toLowerCase()
            .replace(/[^\w\u4e00-\u9fa5]+/g, '-')
            .replace(/^-|-$/g, '') || `heading-${index}`;
          heading.id = id;
        }
      });

      // 生成目录项（嵌套结构）
      const headingMap = new Map();
      let currentH1 = null;
      let currentH2 = null;
      let currentH3 = null;
      let currentH4 = null;
      let currentH5 = null;

      headings.forEach((heading) => {
        const level = parseInt(heading.tagName.charAt(1));
        const text = heading.textContent || '';
        const id = heading.id;

        const li = document.createElement('li');
        li.className = `toc-item toc-item-h${level}`;
        
        const a = document.createElement('a');
        a.href = `#${id}`;
        a.className = 'toc-link';
        a.textContent = text;
        
        // 平滑滚动
        a.addEventListener('click', (e) => {
          e.preventDefault();
          const target = document.getElementById(id) as HTMLElement;
          if (target) {
            const offsetTop = target.offsetTop - 80;
            window.scrollTo({
              top: offsetTop,
              behavior: 'smooth'
            });
            // 更新 URL 但不触发滚动
            history.pushState(null, '', `#${id}`);
          }
        });

        li.appendChild(a);

        // 嵌套目录结构
        if (level === 1) {
          // 创建子目录列表
          const subList = document.createElement('ul');
          subList.className = 'toc-list';
          li.appendChild(subList);
          tocList.appendChild(li);
          currentH1 = li;
          currentH2 = null;
          currentH3 = null;
          currentH4 = null;
          currentH5 = null;
        } else if (level === 2 && currentH1) {
          const subList = currentH1.querySelector('.toc-list');
          if (subList) {
            subList.appendChild(li);
            currentH2 = li;
            currentH3 = null;
            currentH4 = null;
            currentH5 = null;
          }
        } else if (level === 3 && currentH2) {
          // 为H2创建子目录列表
          let subList = currentH2.querySelector('.toc-list');
          if (!subList) {
            subList = document.createElement('ul');
            subList.className = 'toc-list';
            currentH2.appendChild(subList);
          }
          subList.appendChild(li);
          currentH3 = li;
          currentH4 = null;
          currentH5 = null;
        } else if (level === 4 && currentH3) {
          // 为H3创建子目录列表
          let subList = currentH3.querySelector('.toc-list');
          if (!subList) {
            subList = document.createElement('ul');
            subList.className = 'toc-list';
            currentH3.appendChild(subList);
          }
          subList.appendChild(li);
          currentH4 = li;
          currentH5 = null;
        } else if (level === 5 && currentH4) {
          // 为H4创建子目录列表
          let subList = currentH4.querySelector('.toc-list');
          if (!subList) {
            subList = document.createElement('ul');
            subList.className = 'toc-list';
            currentH4.appendChild(subList);
          }
          subList.appendChild(li);
          currentH5 = li;
        } else if (level === 6 && currentH5) {
          // 为H5创建子目录列表
          let subList = currentH5.querySelector('.toc-list');
          if (!subList) {
            subList = document.createElement('ul');
            subList.className = 'toc-list';
            currentH5.appendChild(subList);
          }
          subList.appendChild(li);
        }

        // 存储标题映射
        headingMap.set(id, li);
      });

      // 添加H1点击事件，实现折叠/展开
      document.querySelectorAll('.toc-item-h1 > .toc-link').forEach((link) => {
        link.addEventListener('click', function(e) {
          const parent = this.closest('.toc-item-h1');
          if (parent) {
            parent.classList.toggle('expanded');
          }
        });
      });

      // 监听滚动，高亮当前章节并展开对应目录
      let currentActive = '';
      const observerOptions = {
        rootMargin: '-80px 0px -80% 0px',
        threshold: 0
      };

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const id = entry.target.id;
            if (id && id !== currentActive) {
              // 移除旧的 active 类
              document.querySelectorAll('.toc-link.active').forEach((link) => {
                link.classList.remove('active');
              });
              
              // 添加新的 active 类
              const activeLink = document.querySelector(`.toc-link[href="#${id}"]`);
              if (activeLink) {
                activeLink.classList.add('active');
                currentActive = id;
                
                // 展开所有父级目录
                let current = activeLink.closest('.toc-item');
                while (current) {
                  if (current.classList.contains('toc-item-h1')) {
                    current.classList.add('expanded');
                  }
                  current = current.parentElement?.closest('.toc-item');
                }
                
                // 滚动到可见区域（如果需要）
                const sidebar = document.getElementById('toc-sidebar') as HTMLElement;
                if (sidebar && (activeLink as HTMLElement).offsetTop > sidebar.scrollTop + sidebar.clientHeight - 100) {
                  sidebar.scrollTo({
                    top: (activeLink as HTMLElement).offsetTop - 100,
                    behavior: 'smooth'
                  });
                }
              }
            }
          }
        });
      }, observerOptions);

      // 观察所有标题
      headings.forEach((heading) => {
        observer.observe(heading);
      });

      // 处理页面加载时的 hash
      if (window.location.hash) {
        const hash = window.location.hash.substring(1);
        const target = document.getElementById(hash) as HTMLElement;
        if (target) {
          setTimeout(() => {
            const offsetTop = target.offsetTop - 80;
            window.scrollTo({
              top: offsetTop,
              behavior: 'smooth'
            });
            const activeLink = document.querySelector(`.toc-link[href="#${hash}"]`);
            if (activeLink) {
              activeLink.classList.add('active');
              
              // 展开所有父级目录
              let current = activeLink.closest('.toc-item');
              while (current) {
                if (current.classList.contains('toc-item-h1')) {
                  current.classList.add('expanded');
                }
                current = current.parentElement?.closest('.toc-item');
              }
            }
          }, 100);
        }
      }
    }

    // 页面加载完成后生成目录并更新阅读时间
    function init() {
      generateTOC();
      updateReadingTime();
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  </script>
</BaseLayout>
