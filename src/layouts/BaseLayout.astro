---
interface Props {
  title: string;
}

const { title } = Astro.props;
---
<html lang="zh">
  <head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@500;700&family=Outfit:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
      :root {
        --bg: #f6fbf8;
        --bg-accent: #eef7f1;
        --surface: rgba(255, 255, 255, 0.84);
        --surface-strong: #ffffff;
        --surface-border: rgba(142, 175, 156, 0.22);
        --text: #24332d;
        --muted: #6c7f75;
        --primary: #69b38f;
        --primary-deep: #4d9273;
        --shadow: 0 20px 60px rgba(89, 124, 106, 0.08);
        --radius-xl: 28px;
        --radius-lg: 20px;
        --radius-md: 14px;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: "Outfit", "PingFang SC", "Microsoft YaHei", sans-serif;
        background:
          radial-gradient(circle at top left, rgba(177, 220, 196, 0.42), transparent 36%),
          radial-gradient(circle at top right, rgba(206, 235, 220, 0.5), transparent 32%),
          linear-gradient(180deg, #fafdfe 0%, var(--bg) 52%, #f9fcfa 100%);
        min-height: 100vh;
        color: var(--text);
        line-height: 1.7;
        display: flex;
        flex-direction: column;
        position: relative;
        overflow-x: hidden;
      }

      body::before {
        content: '';
        position: fixed;
        inset: 0;
        background-image:
          linear-gradient(rgba(120, 161, 140, 0.045) 1px, transparent 1px),
          linear-gradient(90deg, rgba(120, 161, 140, 0.045) 1px, transparent 1px);
        background-size: 32px 32px;
        pointer-events: none;
        opacity: 0.55;
      }

      .header {
        max-width: 1180px;
        width: calc(100% - 28px);
        margin: 18px auto 0;
        display: grid;
        grid-template-columns: auto 1fr auto;
        gap: 18px;
        justify-content: space-between;
        position: relative;
        align-items: center;
        padding: 16px 20px;
        background: var(--surface);
        box-shadow: var(--shadow);
        border: 1px solid var(--surface-border);
        border-radius: 999px;
        backdrop-filter: blur(20px);
        z-index: 2;
      }

      .header-left {
        display: flex;
        align-items: center;
        gap: 12px;
        min-width: 0;
      }

      .header-left img {
        width: 32px;
        height: 32px;
        cursor: pointer;
        transition: transform 0.28s ease, box-shadow 0.28s ease;
        border-radius: 10px;
        box-shadow: 0 8px 20px rgba(105, 179, 143, 0.18);
      }

      .header-left img:hover {
        transform: translateY(-1px) scale(1.04);
      }

      .brand-link {
        text-decoration: none;
        color: var(--text);
        display: flex;
        flex-direction: column;
        gap: 1px;
        min-width: 0;
      }

      .brand-link strong {
        font-family: "Noto Serif SC", serif;
        font-size: 1rem;
        font-weight: 700;
        letter-spacing: 0.04em;
      }

      .brand-link span {
        color: var(--muted);
        font-size: 0.73rem;
      }

      .nav-links {
        display: flex;
        justify-content: center;
        gap: 8px;
        flex-wrap: wrap;
      }

      .nav-links a,
      .rss-icon-link {
        position: relative;
        text-decoration: none;
        color: var(--muted);
        font-weight: 500;
        padding: 10px 14px;
        border-radius: 999px;
        transition: color 0.28s ease, background 0.28s ease, transform 0.28s ease;
      }

      .nav-links a::after {
        content: '';
        position: absolute;
        width: 0;
        height: 2px;
        bottom: 6px;
        left: 50%;
        background-color: var(--primary);
        transition: all 0.3s ease;
      }

      .nav-links a:hover,
      .rss-icon-link:hover {
        color: var(--primary-deep);
        background: rgba(105, 179, 143, 0.1);
        transform: translateY(-1px);
      }

      .nav-links a:hover::after {
        width: calc(100% - 28px);
        left: 14px;
      }

      .rss-icon-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 42px;
        height: 42px;
        padding: 0;
        color: var(--primary-deep);
        background: rgba(105, 179, 143, 0.12);
      }

      .rss-icon-link svg {
        fill: currentColor;
      }

      main {
        flex: 1;
        position: relative;
        z-index: 1;
        padding: 28px 0 0;
      }

      .page-shell {
        max-width: 1180px;
        margin: 0 auto;
        padding: 0 20px;
      }

      .footer {
        margin: 38px auto 24px;
        width: calc(100% - 28px);
        max-width: 1180px;
        padding: 24px 26px;
        background: var(--surface);
        text-align: center;
        color: var(--muted);
        font-size: 0.88rem;
        border: 1px solid var(--surface-border);
        border-radius: var(--radius-xl);
        backdrop-filter: blur(20px);
        box-shadow: var(--shadow);
      }

      .footer-content {
        max-width: 860px;
        margin: 0 auto;
      }

      .footer p {
        margin: 6px 0;
      }

      .footer-links {
        display: flex;
        justify-content: center;
        gap: 12px;
        margin-top: 14px;
        flex-wrap: wrap;
      }

      .footer-links a {
        color: var(--muted);
        text-decoration: none;
        padding: 8px 12px;
        border-radius: 999px;
        transition: color 0.28s ease, background 0.28s ease;
      }

      .footer-links a:hover {
        color: var(--primary-deep);
        background: rgba(105, 179, 143, 0.1);
      }

      @media (max-width: 768px) {
        .header {
          grid-template-columns: 1fr;
          border-radius: 28px;
          padding: 16px;
          gap: 14px;
        }

        .footer {
          padding: 20px 16px;
          font-size: 0.85rem;
        }

        .header-left,
        .nav-links {
          justify-content: center;
          text-align: center;
        }

        .footer-links {
          gap: 8px;
        }
      }
    </style>
  </head>
  <body>
    <header class="header">
      <div class="header-left">
        <img src="/favicon.ico" alt="首页" onclick="window.location.href='/'">
        <a href="/" class="brand-link">
          <strong>木风的小站</strong>
          <span>记录日常，分享一些有用的东西</span>
        </a>
      </div>
      <nav class="nav-links">
        <a href="/blog/">博客</a>
        <a href="/thoughts/">碎碎念</a>
        <a href="/borrow/">他山之石</a>
        <a href="/friends/">看看他们</a>
      </nav>
      <a href="/rss.xml" target="_blank" rel="noopener noreferrer" class="rss-icon-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24">
          <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27zm0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93z"></path>
        </svg>
      </a>

    </header>

    <main>
      <div class="page-shell">
        <slot />
      </div>
    </main>

    <footer class="footer">
      <div class="footer-content">
        <p>© 2025 木风. 保留所有权利.</p>
        <div class="footer-links">
          <a href="/">首页</a>
          <a href="/blog/">博客</a>
          <a href="/thoughts/">碎碎念</a>
          <a href="/borrow/">他山之石</a>
          <a href="/friends/">看看他们</a>
        </div>
        <p style="margin-top: 15px; font-size: 0.85rem;">愿你每一天都充满阳光 ☀️</p>
      </div>
    </footer>
    <script src="https://fastly.jsdelivr.net/gh/stevenjoezhang/live2d-widget@latest/autoload.js"></script>
  </body>
</html>
