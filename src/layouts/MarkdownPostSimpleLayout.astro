---
import BaseLayout from './BaseLayout.astro';
import NativeComments from '../components/NativeComments.astro';
import { calculateReadingTime } from '../components/lib/reading-time';
import '../styles/markdown-fresh.css';

type RawContent = (() => string) | string;

const { frontmatter = {}, rawContent } = Astro.props as {
  frontmatter?: Record<string, unknown>;
  rawContent?: RawContent;
};

const title = String(frontmatter.title ?? '文章');
const category = frontmatter.category ? String(frontmatter.category) : '';
const description = frontmatter.description ? String(frontmatter.description) : '';
const showToc = frontmatter.toc !== false;
const showComments = frontmatter.comments !== false;

const rawMarkdown = rawContent ? (typeof rawContent === 'function' ? rawContent() : rawContent) : '';
const readingTimeMinutes = rawMarkdown ? calculateReadingTime(rawMarkdown) : null;

function formatDate(value: unknown) {
  if (!value) return '';

  const date = value instanceof Date ? value : new Date(String(value));
  if (Number.isNaN(date.getTime())) {
    return String(value);
  }

  return new Intl.DateTimeFormat('zh-CN', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  }).format(date);
}

const pubdate = formatDate(frontmatter.pubdate);
---

<BaseLayout title={`${title} - 木风`}>
  <style>
    .post-alt-shell {
      max-width: 1120px;
      margin: 0 auto 36px;
      display: grid;
      grid-template-columns: minmax(0, 1fr) 250px;
      gap: 28px;
      align-items: start;
    }

    .post-alt-shell-no-toc {
      max-width: 900px;
      grid-template-columns: minmax(0, 1fr);
    }

    .post-alt-main {
      min-width: 0;
    }

    .post-alt-breadcrumb {
      display: flex;
      align-items: center;
      gap: 9px;
      margin-bottom: 18px;
      color: #769083;
      font-size: 0.86rem;
    }

    .post-alt-breadcrumb a {
      color: #4d9273;
      text-decoration: none;
      font-weight: 600;
    }

    .post-alt-breadcrumb span:last-child {
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .post-alt-hero {
      padding: 10px 0 28px;
      margin-bottom: 24px;
      border-bottom: 1px solid rgba(142, 175, 156, 0.22);
    }

    .post-alt-kicker {
      margin-bottom: 12px;
      color: #4d9273;
      font-size: 0.76rem;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    .post-alt-title {
      max-width: 820px;
      margin: 0;
      color: #1f302a;
      font-family: "Noto Serif SC", serif;
      font-size: clamp(2rem, 4vw, 3.15rem);
      line-height: 1.22;
      font-weight: 700;
    }

    .post-alt-description {
      max-width: 720px;
      margin: 14px 0 0;
      color: #52685e;
      font-size: 1.02rem;
      line-height: 1.85;
    }

    .post-alt-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 18px;
      color: #5f766b;
      font-size: 0.9rem;
    }

    .post-alt-meta-item {
      display: inline-flex;
      align-items: center;
      min-height: 34px;
      padding: 6px 12px;
      border: 1px solid rgba(142, 175, 156, 0.2);
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.68);
    }

    .post-alt-meta-item-strong {
      color: #3f7c62;
      background: rgba(105, 179, 143, 0.13);
      border-color: rgba(105, 179, 143, 0.2);
    }

    .post-alt-body,
    .post-alt-comments {
      background: rgba(255, 255, 255, 0.82);
      border: 1px solid rgba(142, 175, 156, 0.18);
      border-radius: 24px;
      box-shadow: 0 22px 52px rgba(89, 124, 106, 0.08);
      backdrop-filter: blur(18px);
    }

    .post-alt-body {
      padding: 42px 46px;
    }

    .post-alt-content {
      color: #304238;
      font-size: 1.03rem;
      line-height: 1.95;
    }

    .post-alt-content :global(h1),
    .post-alt-content :global(h2),
    .post-alt-content :global(h3),
    .post-alt-content :global(h4),
    .post-alt-content :global(h5),
    .post-alt-content :global(h6) {
      scroll-margin-top: 92px;
      color: #20322b;
      letter-spacing: 0;
    }

    .post-alt-content :global(h2) {
      margin-top: 2.35em;
      padding-top: 0.15em;
      font-size: 1.62rem;
    }

    .post-alt-content :global(h3) {
      margin-top: 2em;
      font-size: 1.28rem;
    }

    .post-alt-content :global(pre) {
      border-radius: 14px;
      background: #f4f7f5;
    }

    .post-alt-content :global(table) {
      display: block;
      overflow-x: auto;
      border-radius: 14px;
    }

    .post-alt-toc {
      position: sticky;
      top: 18px;
      max-height: calc(100vh - 36px);
      overflow: auto;
      padding: 18px;
      border: 1px solid rgba(142, 175, 156, 0.18);
      border-radius: 20px;
      background: rgba(255, 255, 255, 0.76);
      box-shadow: 0 18px 44px rgba(89, 124, 106, 0.08);
      backdrop-filter: blur(18px);
    }

    .post-alt-toc-title {
      margin-bottom: 12px;
      padding-bottom: 10px;
      border-bottom: 1px solid rgba(142, 175, 156, 0.18);
      color: #24332d;
      font-size: 0.92rem;
      font-weight: 700;
    }

    .post-alt-toc-list {
      list-style: none;
      margin: 0;
      padding: 0;
    }

    .alt-toc-item {
      margin: 2px 0;
    }

    .alt-toc-link {
      display: block;
      padding: 7px 10px;
      border-left: 2px solid transparent;
      border-radius: 10px;
      color: #637a70;
      font-size: 0.86rem;
      line-height: 1.45;
      text-decoration: none;
      transition: color 0.22s ease, background 0.22s ease, border-color 0.22s ease;
    }

    .alt-toc-link:hover,
    .alt-toc-link.active {
      color: #3f7c62;
      border-left-color: #69b38f;
      background: rgba(105, 179, 143, 0.1);
    }

    .alt-toc-level-3 .alt-toc-link {
      padding-left: 20px;
      font-size: 0.82rem;
    }

    .alt-toc-level-4 .alt-toc-link {
      padding-left: 30px;
      font-size: 0.8rem;
    }

    .alt-toc-empty {
      padding: 14px 4px;
      color: #81978c;
      font-size: 0.84rem;
      line-height: 1.7;
    }

    .post-alt-comments {
      margin-top: 24px;
      padding: 24px;
    }

    .post-alt-comments-title {
      margin: 0 0 6px;
      color: #24332d;
      font-size: 1.05rem;
      font-weight: 700;
    }

    .post-alt-comments-desc {
      margin: 0 0 16px;
      color: #6c7f75;
      font-size: 0.9rem;
      line-height: 1.8;
    }

    @media (max-width: 980px) {
      .post-alt-shell {
        grid-template-columns: minmax(0, 1fr);
      }

      .post-alt-toc {
        position: static;
        order: -1;
        max-height: none;
      }
    }

    @media (max-width: 768px) {
      .post-alt-shell {
        gap: 18px;
        margin-bottom: 26px;
      }

      .post-alt-hero {
        padding-top: 4px;
      }

      .post-alt-title {
        font-size: 2rem;
      }

      .post-alt-body,
      .post-alt-comments {
        padding: 24px 20px;
        border-radius: 20px;
      }

      .post-alt-content {
        font-size: 0.98rem;
        line-height: 1.86;
      }
    }
  </style>

  <div class:list={['post-alt-shell', !showToc && 'post-alt-shell-no-toc']} data-md-alt>
    <article class="post-alt-main">
      <nav class="post-alt-breadcrumb" aria-label="当前位置">
        <a href="/blog/">博客</a>
        <span>/</span>
        <span>{title}</span>
      </nav>

      <header class="post-alt-hero">
        <div class="post-alt-kicker">{category || 'Post'}</div>
        <h1 class="post-alt-title">{title}</h1>
        {description && <p class="post-alt-description">{description}</p>}
        <div class="post-alt-meta">
          {category && <span class="post-alt-meta-item post-alt-meta-item-strong">{category}</span>}
          {pubdate && <time class="post-alt-meta-item" datetime={String(frontmatter.pubdate)}>{pubdate}</time>}
          <span class="post-alt-meta-item" data-reading-time={readingTimeMinutes === null ? 'pending' : 'ready'}>
            {readingTimeMinutes !== null ? `约 ${readingTimeMinutes} 分钟阅读` : '阅读时间计算中'}
          </span>
        </div>
      </header>

      <div class="post-alt-body">
        <div class="post-content post-alt-content" id="post-content">
          <slot />
        </div>
      </div>

      {showComments && (
        <section class="post-alt-comments">
          <h2 class="post-alt-comments-title">评论区</h2>
          <p class="post-alt-comments-desc">欢迎留下你的想法，或者补充这篇文章里没有写到的内容。</p>
          <NativeComments />
        </section>
      )}
    </article>

    {showToc && (
      <aside class="post-alt-toc" aria-label="文章目录">
        <div class="post-alt-toc-title">目录</div>
        <ul class="post-alt-toc-list" id="alt-toc-list">
          <li class="alt-toc-empty">正在生成目录...</li>
        </ul>
      </aside>
    )}
  </div>

  <script>
    function slugifyHeading(text, index, usedSlugs) {
      const base = text
        .trim()
        .toLowerCase()
        .replace(/[^\w\u4e00-\u9fa5]+/g, '-')
        .replace(/^-+|-+$/g, '') || `section-${index + 1}`;
      const count = usedSlugs.get(base) || 0;
      usedSlugs.set(base, count + 1);
      return count === 0 ? base : `${base}-${count + 1}`;
    }

    function updateReadingTime(content) {
      const readingTime = document.querySelector('[data-reading-time="pending"]');
      if (!readingTime || !content) return;

      const text = content.textContent || '';
      const chineseCount = (text.match(/[\u4e00-\u9fff]/g) || []).length;
      const wordCount = (text.replace(/[\u4e00-\u9fff]/g, ' ').match(/[A-Za-z0-9]+/g) || []).length;
      const minutes = Math.max(1, Math.ceil((chineseCount + wordCount) / 400));
      readingTime.textContent = `约 ${minutes} 分钟阅读`;
      readingTime.setAttribute('data-reading-time', 'ready');
    }

    function generateAltToc() {
      const content = document.getElementById('post-content');
      const tocList = document.getElementById('alt-toc-list');

      if (!content) return;
      updateReadingTime(content);
      if (!tocList) return;

      const headings = Array.from(content.querySelectorAll('h2, h3, h4')).filter((heading) => {
        return (heading.textContent || '').trim().length > 0;
      });

      if (headings.length === 0) {
        tocList.innerHTML = '<li class="alt-toc-empty">暂无目录</li>';
        return;
      }

      const usedSlugs = new Map();
      const linkById = new Map();
      tocList.innerHTML = '';

      headings.forEach((heading, index) => {
        if (!heading.id) {
          heading.id = slugifyHeading(heading.textContent || '', index, usedSlugs);
        }

        const level = heading.tagName.slice(1);
        const item = document.createElement('li');
        item.className = `alt-toc-item alt-toc-level-${level}`;

        const link = document.createElement('a');
        link.className = 'alt-toc-link';
        link.href = `#${heading.id}`;
        link.textContent = heading.textContent || '';
        link.addEventListener('click', (event) => {
          event.preventDefault();
          const top = heading.getBoundingClientRect().top + window.scrollY - 84;
          window.scrollTo({ top, behavior: 'smooth' });
          history.pushState(null, '', `#${heading.id}`);
        });

        item.appendChild(link);
        tocList.appendChild(item);
        linkById.set(heading.id, link);
      });

      const setActiveLink = (id) => {
        linkById.forEach((link) => link.classList.remove('active'));
        const activeLink = linkById.get(id);
        if (activeLink) {
          activeLink.classList.add('active');
        }
      };

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting && entry.target.id) {
            setActiveLink(entry.target.id);
          }
        });
      }, {
        rootMargin: '-20% 0px -70% 0px',
        threshold: 0,
      });

      headings.forEach((heading) => observer.observe(heading));

      if (window.location.hash) {
        const target = document.getElementById(decodeURIComponent(window.location.hash.slice(1)));
        if (target) {
          setActiveLink(target.id);
        }
      } else {
        setActiveLink(headings[0].id);
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', generateAltToc);
    } else {
      generateAltToc();
    }
  </script>
</BaseLayout>
