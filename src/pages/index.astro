---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// 获取所有 quotes
const allQuotes = await getCollection('quotes');
const ruleEntries = await getCollection('starRailRelicRules');

// 随机选择一条
const randomQuote = allQuotes[Math.floor(Math.random() * allQuotes.length)];
---

<BaseLayout title="Read in the air">
	<style>
		.content {
			position: relative;
			min-height: 62vh;
			width: 100%;
			padding: 28px 10px 10px;
      border-radius: 30px;
      background:
        linear-gradient(160deg, rgba(255,255,255,0.78), rgba(247,252,248,0.62)),
        radial-gradient(circle at top right, rgba(178, 218, 194, 0.45), transparent 28%);
      border: 1px solid rgba(142, 175, 156, 0.18);
      box-shadow: 0 24px 60px rgba(89, 124, 106, 0.08);
      overflow: hidden;
		}
		.word-cloud {
			position: absolute;
			display: inline-block;
			font-weight: 600;
			color: #5a9076;
			transition: all 0.28s ease;
			text-decoration: none;
			cursor: pointer;
      letter-spacing: 0.04em;
		}
		.word-cloud:hover {
			color: #3f715b;
			transform: scale(1.1) !important;
			text-shadow: 0 12px 20px rgba(105, 179, 143, 0.18);
			z-index: 10;
		}
		.word-cloud a {
			color: inherit;
			text-decoration: none;
		}

		/* 名言展示样式 */
		.quote-container {
			margin-top: 20px;
			width: 100%;
			max-width: 720px;
      margin-left: auto;
      margin-right: auto;
		}

		.quote-card {
			backdrop-filter: blur(16px);
			border-radius: 24px;
			padding: 28px 30px;
			text-align: center;
      background: rgba(255,255,255,0.68);
      border: 1px solid rgba(142, 175, 156, 0.18);
      box-shadow: 0 22px 44px rgba(96, 135, 113, 0.1);
		}

    .snake-section {
      margin-top: 24px;
      padding: 18px 18px 12px;
      border-radius: 24px;
      background: rgba(255,255,255,0.7);
      border: 1px solid rgba(142, 175, 156, 0.18);
      box-shadow: 0 20px 40px rgba(96, 135, 113, 0.08);
    }

    .snake-title {
      margin-bottom: 10px;
      font-size: 0.86rem;
      letter-spacing: 0.08em;
      color: #71867a;
      text-align: center;
    }

    .snake-image {
      display: block;
      width: 100%;
      height: auto;
      border-radius: 18px;
      background: rgba(244, 250, 246, 0.9);
    }

    .quote-text {
      font-family: "Noto Serif SC", serif;
      font-size: clamp(1.15rem, 2vw, 1.5rem);
      line-height: 1.8;
      color: #24332d;
    }

    .quote-author {
      margin-top: 14px;
      color: #71867a;
      font-size: 0.9rem;
      letter-spacing: 0.08em;
    }

    @media (max-width: 768px) {
      .content {
        min-height: 70vh;
        padding: 24px 10px 20px;
      }

      .quote-container {
        width: 100%;
        max-width: 100%;
        margin-top: 16px;
      }

      .quote-card {
        padding: 22px 20px;
      }

      .snake-section {
        margin-top: 18px;
        padding: 14px 14px 10px;
      }
		}
	</style>
	<div class="content">
		<span class="word-cloud" style="font-size: 48px; top: 18%; left: 15%; transform: rotate(-15deg);">装修中（10/100）</span>
		<span class="word-cloud" style="font-size: 32px; top: 30%; left: 50%; transform: rotate(10deg);">崩坏：星穹铁道</span>
		<span class="word-cloud" style="font-size: 42px; top: 55%; left: 35%; transform: rotate(5deg);">感谢<a href="https://www.viki.moe/">viki</a></span>
		<span class="word-cloud" style="font-size: 32px; top: 39%; left: 68%; transform: rotate(-7deg);">python</span>
		<span class="word-cloud" style="font-size: 32px; top: 45%; left: 23%; transform: rotate(5deg);">工程造价</span>
		<span class="word-cloud" style="font-size: 32px; top: 65%; left: 60%; transform: rotate(-12deg);">辅助</span>
		
	</div>
  <!-- 随机名言展示 -->
  <div class="quote-container">
    <div class="quote-card">
      <div class="quote-text">"{randomQuote.data.text}"</div>
      <div class="quote-author">—— {randomQuote.data.author}</div>
    </div>
  </div>

    <section class="snake-section">
      <div class="snake-title">GitHub Contribution Snake</div>
      <img
        class="snake-image"
        src="https://raw.githubusercontent.com/mufeng520/mufeng520.github.io/snake/snake.svg"
        alt="GitHub contribution snake"
        loading="lazy"
      />
    </section>
</BaseLayout>
