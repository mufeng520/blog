---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// 获取所有 quotes
const allQuotes = await getCollection('quotes');
const ruleEntries = await getCollection('starRailRelicRules');

// 随机选择一条
const randomQuote = allQuotes[Math.floor(Math.random() * allQuotes.length)];
---

<BaseLayout title="Read in the air">
	<style>
		.content {
			position: relative;
			min-height: 70vh;
			width: 100%;
			padding: 20px;
		}
		.word-cloud {
			position: absolute;
			display: inline-block;
			font-weight: bold;
			color: #00a8e8;
			transition: all 0.3s ease;
			text-decoration: none;
			cursor: pointer;
		}
		.word-cloud:hover {
			color: #0077b6;
			transform: scale(1.1) !important;
			text-shadow: 0 4px 8px rgba(0, 168, 232, 0.3);
			z-index: 10;
		}
		.word-cloud a {
			color: inherit;
			text-decoration: none;
		}

		/* 名言展示样式 */
		.quote-container {
			position: absolute;
			bottom: 10%;
			left: 50%;
			transform: translateX(-50%);
			width: 80%;
			max-width: 600px;
			z-index: 5;
		}

		.quote-card {
			backdrop-filter: blur(10px);
			border-radius: 16px;
			padding: 24px 32px;
			text-align: center;
		}
	</style>
	<div class="content">
		<span class="word-cloud" style="font-size: 48px; top: 18%; left: 15%; transform: rotate(-15deg);">装修中（10/100）</span>
		<span class="word-cloud" style="font-size: 32px; top: 30%; left: 50%; transform: rotate(10deg);">崩坏：星穹铁道</span>
		<span class="word-cloud" style="font-size: 42px; top: 55%; left: 35%; transform: rotate(5deg);">感谢<a href="https://www.viki.moe/">viki</a></span>
		<span class="word-cloud" style="font-size: 32px; top: 39%; left: 68%; transform: rotate(-7deg);">python</span>
		<span class="word-cloud" style="font-size: 32px; top: 45%; left: 23%; transform: rotate(5deg);">工程造价</span>
		<span class="word-cloud" style="font-size: 32px; top: 65%; left: 60%; transform: rotate(-12deg);">辅助</span>
		
	</div>
	<!-- 随机名言展示 -->
		<div class="quote-container">
			<div class="quote-card">
				<div class="quote-text">"{randomQuote.data.text}"</div>
				<div class="quote-author">—— {randomQuote.data.author}</div>
			</div>
			{ruleEntries}
		</div>
</BaseLayout>
