---
import BaseLayout from '../layouts/BaseLayout.astro';

// 获取所有文章
const allPosts = Object.values(import.meta.glob('./posts/*.md', { eager: true }))
  .map((post: any) => ({
    ...post,
    // 确保有分类字段，默认为"未分类"
    category: post.frontmatter?.category || '未分类',
    // 确保有发布日期
    pubdate: post.frontmatter?.pubdate || '',
  }))
  // 按发布日期排序（最新的在前）
  .sort((a: any, b: any) => {
    const dateA = a.pubdate ? new Date(a.pubdate).getTime() : 0;
    const dateB = b.pubdate ? new Date(b.pubdate).getTime() : 0;
    return dateB - dateA;
  });

// 获取所有分类
const categories = Array.from(new Set(allPosts.map((post: any) => post.category))).sort();
---
<BaseLayout title="博客 - 木风">
  <style>
    .container {
      max-width: 900px;
      margin: 0 auto;
      padding: 0 20px;
    }

    .page-title {
      text-align: center;
      font-size: 2.5rem;
      color: #2d3748;
      margin-bottom: 30px;
      font-weight: 300;
      letter-spacing: 2px;
    }

    /* 搜索和筛选区域 */
    .search-filter-section {
      background: rgba(255, 255, 255, 0.9);
      backdrop-filter: blur(10px);
      border-radius: 16px;
      padding: 24px;
      margin-bottom: 30px;
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
      border: 1px solid rgba(255, 255, 255, 0.5);
    }

    .search-box {
      width: 100%;
      padding: 12px 16px;
      font-size: 1rem;
      border: 2px solid rgba(96, 165, 250, 0.3);
      border-radius: 12px;
      background: rgba(255, 255, 255, 0.8);
      color: #2d3748;
      transition: all 0.3s ease;
      margin-bottom: 20px;
    }

    .search-box:focus {
      outline: none;
      border-color: #60a5fa;
      box-shadow: 0 0 0 3px rgba(96, 165, 250, 0.2);
    }

    .search-box::placeholder {
      color: #a0aec0;
    }

    .categories-section {
      margin-top: 20px;
    }

    .categories-label {
      font-size: 0.9rem;
      color: #718096;
      margin-bottom: 12px;
      font-weight: 500;
    }

    .categories-list {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    .category-btn {
      padding: 8px 16px;
      border: 2px solid rgba(96, 165, 250, 0.3);
      background: rgba(255, 255, 255, 0.8);
      color: #4a5568;
      border-radius: 20px;
      cursor: pointer;
      font-size: 0.9rem;
      transition: all 0.3s ease;
      font-weight: 500;
    }

    .category-btn:hover {
      background: rgba(96, 165, 250, 0.1);
      border-color: #60a5fa;
      transform: translateY(-2px);
    }

    .category-btn.active {
      background: linear-gradient(90deg, #60a5fa, #a78bfa);
      color: white;
      border-color: transparent;
      box-shadow: 0 4px 12px rgba(96, 165, 250, 0.3);
    }

    .posts-count {
      margin-top: 20px;
      font-size: 0.9rem;
      color: #718096;
      text-align: center;
    }

    .posts-list {
      list-style: none;
      display: grid;
      gap: 20px;
    }

    .post-item {
      background: rgba(255, 255, 255, 0.9);
      border-radius: 16px;
      padding: 24px;
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
      transition: all 0.3s ease;
      border: 1px solid rgba(255, 255, 255, 0.5);
      opacity: 1;
      transform: scale(1);
    }

    .post-item.hidden {
      display: none;
    }

    .post-item:hover {
      transform: translateY(-5px);
      box-shadow: 0 8px 25px rgba(236, 72, 153, 0.25);
    }

    .post-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 12px;
      gap: 15px;
    }

    .post-title-link {
      text-decoration: none;
      color: #2d3748;
      font-size: 1.3rem;
      font-weight: 600;
      display: block;
      transition: color 0.3s ease;
      flex: 1;
    }

    .post-title-link:hover {
      color: #ec4899;
    }

    .post-category {
      display: inline-block;
      padding: 4px 12px;
      background: linear-gradient(90deg, #60a5fa, #a78bfa);
      color: white;
      border-radius: 12px;
      font-size: 0.75rem;
      font-weight: 500;
      white-space: nowrap;
    }

    .post-meta {
      display: flex;
      align-items: center;
      gap: 15px;
      color: #718096;
      font-size: 0.9rem;
      margin-top: 8px;
    }

    .post-date {
      display: flex;
      align-items: center;
      gap: 5px;
    }

    .empty-state {
      text-align: center;
      padding: 60px 20px;
      color: #a0aec0;
    }

    .empty-state-icon {
      font-size: 4rem;
      margin-bottom: 20px;
    }

    .empty-state-text {
      font-size: 1.1rem;
    }

    @media (max-width: 768px) {
      .page-title {
        font-size: 2rem;
      }

      .container {
        padding: 0 15px;
      }

      .search-filter-section {
        padding: 20px;
      }

      .post-header {
        flex-direction: column;
        align-items: flex-start;
      }

      .post-title-link {
        font-size: 1.1rem;
      }
    }
  </style>

  <div class="container">
    <h1 class="page-title">我的博客</h1>
    
    <div class="search-filter-section">
      <input 
        type="text" 
        id="searchInput" 
        class="search-box" 
        placeholder="🔍 搜索文章标题或内容..."
      />
      
      <div class="categories-section">
        <div class="categories-label">📂 分类筛选：</div>
        <div class="categories-list">
          <button class="category-btn active" data-category="all">
            全部 ({allPosts.length})
          </button>
          {categories.map((category) => {
            const count = allPosts.filter((p: any) => p.category === category).length;
            return (
              <button class="category-btn" data-category={category}>
                {category} ({count})
              </button>
            );
          })}
        </div>
      </div>
      
      <div class="posts-count" id="postsCount">
        显示 {allPosts.length} 篇文章
      </div>
    </div>

    <ul class="posts-list" id="postsList">
      {allPosts.map((post: any) => (
        <li class="post-item" data-category={post.category} data-title={post.frontmatter.title.toLowerCase()}>
          <div class="post-header">
            <a href={post.url} class="post-title-link">
              {post.frontmatter.title}
            </a>
            <span class="post-category">{post.category}</span>
          </div>
          {post.pubdate && (
            <div class="post-meta">
              <div class="post-date">
                <span>📅</span>
                <time>{post.pubdate}</time>
              </div>
            </div>
          )}
        </li>
      ))}
    </ul>

    <div class="empty-state hidden" id="emptyState">
      <div class="empty-state-icon">🔍</div>
      <div class="empty-state-text">没有找到匹配的文章</div>
    </div>
  </div>

  <script>
    const searchInput = document.getElementById('searchInput');
    const categoryButtons = document.querySelectorAll('.category-btn');
    const postItems = document.querySelectorAll('.post-item');
    const postsCount = document.getElementById('postsCount');
    const emptyState = document.getElementById('emptyState');
    const postsList = document.getElementById('postsList');

    let currentCategory = 'all';
    let currentSearch = '';

    // 搜索功能
    searchInput?.addEventListener('input', (e) => {
      currentSearch = (e.target as HTMLInputElement).value.toLowerCase().trim();
      filterPosts();
    });

    // 分类筛选功能
    categoryButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        // 更新按钮状态
        categoryButtons.forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');
        
        currentCategory = btn.getAttribute('data-category') || 'all';
        filterPosts();
      });
    });

    function filterPosts() {
      let visibleCount = 0;

      postItems.forEach((item) => {
        const category = item.getAttribute('data-category') || '';
        const title = item.getAttribute('data-title') || '';
        
        // 分类筛选
        const categoryMatch = currentCategory === 'all' || category === currentCategory;
        
        // 搜索筛选
        const searchMatch = !currentSearch || title.includes(currentSearch);
        
        // 显示/隐藏
        if (categoryMatch && searchMatch) {
          item.classList.remove('hidden');
          visibleCount++;
        } else {
          item.classList.add('hidden');
        }
      });

      // 更新计数
      if (postsCount) {
        postsCount.textContent = `显示 ${visibleCount} 篇文章`;
      }

      // 显示/隐藏空状态
      if (visibleCount === 0) {
        emptyState?.classList.remove('hidden');
        postsList?.classList.add('hidden');
      } else {
        emptyState?.classList.add('hidden');
        postsList?.classList.remove('hidden');
      }
    }
  </script>
</BaseLayout>
