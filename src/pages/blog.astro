---
import BaseLayout from '../layouts/BaseLayout.astro';
import { calculateReadingTime } from '../components/lib/reading-time';

// 获取所有文章
const allPosts = Object.values(import.meta.glob('./posts/*.md', { eager: true }))
  .map((post: any) => {
    const pubdate = post.frontmatter?.pubdate || '';
    const year = pubdate ? String(new Date(pubdate).getFullYear()) : '';
    // 使用正确的rawContent属性获取原始Markdown内容
    const rawContent = typeof post.rawContent === 'function' ? post.rawContent() : post.rawContent || '';
    const readingTime = calculateReadingTime(rawContent);
    return {
      ...post,
      category: post.frontmatter?.category || '未分类',
      pubdate,
      year,
      readingTime,
    };
  })
  .sort((a: any, b: any) => {
    const dateA = a.pubdate ? new Date(a.pubdate).getTime() : 0;
    const dateB = b.pubdate ? new Date(b.pubdate).getTime() : 0;
    return dateB - dateA;
  });

// 获取所有分类
const categories = Array.from(new Set(allPosts.map((post: any) => post.category))).sort();

// 获取所有年份（按倒序）
const years = Array.from(new Set(allPosts.map((post: any) => post.year).filter(Boolean))).sort((a, b) => Number(b) - Number(a));
---

<BaseLayout title="博客 - 木风">
  <style>
    /* PV 风格布局 */
    .blog-main-wrap {
      padding: 40px 0 60px;
      background: #fafafa;
    }
    .blog-wrapper {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 20px;
      display: flex;
      gap: 40px;
    }
    .blog-main-left {
      flex: 0 0 220px;
    }
    .blog-main-right {
      flex: 1;
      min-width: 0;
    }

    /* 侧边栏 */
    .blog-slideBar .title {
      margin-bottom: 30px;
    }
    .blog-slideBar .title h4 {
      font-size: 24px;
      font-weight: 300;
      letter-spacing: 2px;
      margin-bottom: 8px;
      color: #333;
    }
    .blog-slideBar .title p {
      font-size: 14px;
      color: #666;
    }
    .blog-slideBar .title p i {
      color: #00a8e8;
      margin: 0 4px;
    }
    /* RSS订阅按钮 */
    .blog-rss {
      margin-bottom: 20px;
    }
    .rss-link {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 10px 16px;
      background: linear-gradient(135deg, #ff6b6b 0%, #ee5a5a 100%);
      color: #fff;
      text-decoration: none;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 500;
      transition: all 0.3s ease;
      box-shadow: 0 2px 8px rgba(238, 90, 90, 0.3);
    }
    .rss-link:hover {
      transform: translateY(-2px);
      box-shadow: 0 4px 12px rgba(238, 90, 90, 0.4);
    }
    .rss-icon {
      font-size: 16px;
    }
    .blog-filter dl {
      margin-bottom: 25px;
    }
    .blog-filter dt {
      margin-bottom: 12px;
    }
    .blog-filter dt .t1 {
      font-size: 12px;
      color: #999;
      letter-spacing: 1px;
    }
    .blog-filter dt .t2 {
      font-size: 13px;
      color: #555;
    }
    .blog-filter dd {
      margin: 8px 0;
    }
    .blog-filter dd a,
    .blog-filter dd button {
      color: #666;
      text-decoration: none;
      font-size: 14px;
      transition: color 0.3s;
      cursor: pointer;
      background: none;
      border: none;
      padding: 0;
      font-family: inherit;
      text-align: left;
      width: 100%;
    }
    .blog-filter dd a:hover,
    .blog-filter dd button:hover,
    .blog-filter dd.active a,
    .blog-filter dd.active button {
      color: #00a8e8;
    }

    /* 右侧内容区 */
    .blog-content-header {
      margin-bottom: 24px;
    }
    .blog-search-box {
      width: 100%;
      padding: 12px 16px;
      font-size: 1rem;
      border: 2px solid #eee;
      border-radius: 12px;
      background: #fff;
      color: #333;
      transition: all 0.3s ease;
    }
    .blog-search-box:focus {
      outline: none;
      border-color: #00a8e8;
      box-shadow: 0 0 0 3px rgba(0, 168, 232, 0.15);
    }
    .blog-search-box::placeholder {
      color: #999;
    }
    .blog-posts-count {
      margin-top: 12px;
      font-size: 0.9rem;
      color: #666;
    }

    /* 文章列表 */
    .blog-posts-list {
      list-style: none;
      display: grid;
      gap: 20px;
    }
    .blog-posts-list.hidden {
      display: none !important;
    }
    .blog-post-item {
      background: #fff;
      border-radius: 16px;
      padding: 24px;
      box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
      transition: all 0.3s ease;
      border: 1px solid #eee;
    }
    .blog-post-item.hidden {
      display: none !important;
    }
    .blog-post-item:hover {
      transform: translateY(-5px);
      box-shadow: 0 8px 24px rgba(0, 168, 232, 0.15);
    }
    .blog-post-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 12px;
      gap: 15px;
    }
    .blog-post-title-link {
      text-decoration: none;
      color: #333;
      font-size: 1.3rem;
      font-weight: 600;
      display: block;
      transition: color 0.3s ease;
      flex: 1;
    }
    .blog-post-title-link:hover {
      color: #00a8e8;
    }
    .blog-post-category {
      display: inline-block;
      padding: 4px 12px;
      background: #00a8e8;
      color: #fff;
      border-radius: 12px;
      font-size: 0.75rem;
      font-weight: 500;
      white-space: nowrap;
    }
    .blog-post-meta {
      display: flex;
      align-items: center;
      gap: 15px;
      color: #666;
      font-size: 0.9rem;
      margin-top: 8px;
    }

    /* 空状态 - 修复显示 */
    .blog-empty-wrapper {
      min-height: 300px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .blog-empty-state {
      text-align: center;
      padding: 60px 40px;
      color: #999;
      background: #fff;
      border-radius: 16px;
      border: 1px solid #eee;
      box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
    }
    .blog-empty-state.hidden {
      display: none !important;
    }
    .blog-empty-state-icon {
      font-size: 4rem;
      margin-bottom: 20px;
      opacity: 0.6;
    }
    .blog-empty-state-text {
      font-size: 1.1rem;
      color: #666;
    }

    @media (max-width: 768px) {
      .blog-wrapper {
        flex-direction: column;
      }
      .blog-main-left {
        flex: none;
      }
      .blog-post-header {
        flex-direction: column;
        align-items: flex-start;
      }
      .blog-post-title-link {
        font-size: 1.1rem;
      }
    }
  </style>

  <div class="blog-main-wrap">
    <div class="blog-wrapper">
      <!-- 左侧边栏 -->
      <div class="blog-main-left">
        <div class="blog-slideBar">
          <div class="title">
            <h4>Mufeng Blog</h4>
            <p><i>{</i><span>文章</span><i>}</i></p>
          </div>
          <div class="blog-rss">
            <a href="/rss.xml" target="_blank" class="rss-link">
              <span class="rss-icon">📡</span>
              <span>RSS订阅</span>
            </a>
          </div>
          <div class="blog-filter">
            <dl>
              <dt>
                <p class="t1">FILTER</p>
                <p class="t2">分类索引</p>
              </dt>
              <dd class="active">
                <button type="button" class="filter-btn" data-category="all">所有文章</button>
              </dd>
              {categories.map((category) => {
                const count = allPosts.filter((p: any) => p.category === category).length;
                return (
                  <dd>
                    <button type="button" class="filter-btn" data-category={category}>{category} ({count})</button>
                  </dd>
                );
              })}
            </dl>
            <dl>
              <dt>
                <p class="t1">TIMELINE</p>
                <p class="t2">时间线</p>
              </dt>
              <dd class="active">
                <button type="button" class="filter-btn" data-year="all">全部</button>
              </dd>
              {years.map((year) => {
                const count = allPosts.filter((p: any) => p.year === year).length;
                return (
                  <dd>
                    <button type="button" class="filter-btn" data-year={year}>{year} ({count})</button>
                  </dd>
                );
              })}
            </dl>
          </div>
        </div>
      </div>

      <!-- 右侧内容 -->
      <div class="blog-main-right">
        <div class="blog-content-header">
          <input
            type="text"
            id="searchInput"
            class="blog-search-box"
            placeholder="🔍 搜索文章标题..."
          />
          <div class="blog-posts-count" id="postsCount">
            显示 {allPosts.length} 篇文章
          </div>
        </div>

        <ul class="blog-posts-list" id="postsList">
          {allPosts.map((post: any) => (
            <li
              class="blog-post-item"
              data-category={post.category}
              data-year={post.year}
              data-title={(post.frontmatter?.title || '').toLowerCase()}
            >
              <div class="blog-post-header">
                <a href={post.url} class="blog-post-title-link">
                  {post.frontmatter?.title}
                </a>
                <span class="blog-post-category">{post.category}</span>
              </div>
              <div class="blog-post-meta">
                {post.pubdate && (
                  <div class="post-date">
                    <span>📅</span>
                    <time>{post.pubdate}</time>
                  </div>
                )}
                <div class="post-reading-time">
                  <span>⏱️</span>
                  <span>{post.readingTime} 分钟阅读</span>
                </div>
              </div>
            </li>
          ))}
        </ul>

        <div class="blog-empty-wrapper">
          <div class="blog-empty-state hidden" id="emptyState">
            <div class="blog-empty-state-icon">🔍</div>
            <div class="blog-empty-state-text">没有找到匹配的文章</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    const searchInput = document.getElementById('searchInput');
    const filterButtons = document.querySelectorAll('.filter-btn');
    const postItems = document.querySelectorAll('.blog-post-item');
    const postsCount = document.getElementById('postsCount');
    const emptyState = document.getElementById('emptyState');
    const postsList = document.getElementById('postsList');

    let currentCategory = 'all';
    let currentYear = 'all';
    let currentSearch = '';

    // 搜索
    searchInput?.addEventListener('input', (e) => {
      currentSearch = (e.target as HTMLInputElement).value.toLowerCase().trim();
      filterPosts();
    });

    // 分类和时间线筛选
    filterButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const category = btn.getAttribute('data-category');
        const year = btn.getAttribute('data-year');

        // 更新按钮状态
        const parentDl = btn.closest('dl');
        parentDl?.querySelectorAll('dd').forEach((dd) => dd.classList.remove('active'));
        btn.closest('dd')?.classList.add('active');

        if (category !== null) {
          currentCategory = category;
        }
        if (year !== null) {
          currentYear = year;
        }
        filterPosts();
      });
    });

    function filterPosts() {
      let visibleCount = 0;

      postItems.forEach((item) => {
        const category = item.getAttribute('data-category') || '';
        const year = item.getAttribute('data-year') || '';
        const title = item.getAttribute('data-title') || '';

        const categoryMatch = currentCategory === 'all' || category === currentCategory;
        const yearMatch = currentYear === 'all' || year === currentYear;
        const searchMatch = !currentSearch || title.includes(currentSearch);

        if (categoryMatch && yearMatch && searchMatch) {
          item.classList.remove('hidden');
          visibleCount++;
        } else {
          item.classList.add('hidden');
        }
      });

      if (postsCount) {
        postsCount.textContent = `显示 ${visibleCount} 篇文章`;
      }

      // 空状态显示
      if (emptyState && postsList) {
        if (visibleCount === 0) {
          emptyState.classList.remove('hidden');
          postsList.classList.add('hidden');
        } else {
          emptyState.classList.add('hidden');
          postsList.classList.remove('hidden');
        }
      }
    }
  </script>
</BaseLayout>
