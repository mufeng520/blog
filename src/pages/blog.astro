---
import BaseLayout from '../layouts/BaseLayout.astro';
import { calculateReadingTime } from '../components/lib/reading-time';

// 获取所有文章
const allPosts = Object.values(import.meta.glob('./posts/*.md', { eager: true }))
  .map((post: any) => {
    const pubdate = post.frontmatter?.pubdate || '';
    const year = pubdate ? String(new Date(pubdate).getFullYear()) : '';
    // 使用正确的rawContent属性获取原始Markdown内容
    const rawContent = typeof post.rawContent === 'function' ? post.rawContent() : post.rawContent || '';
    const readingTime = calculateReadingTime(rawContent);
    return {
      ...post,
      category: post.frontmatter?.category || '未分类',
      pubdate,
      year,
      readingTime,
    };
  })
  .sort((a: any, b: any) => {
    const dateA = a.pubdate ? new Date(a.pubdate).getTime() : 0;
    const dateB = b.pubdate ? new Date(b.pubdate).getTime() : 0;
    return dateB - dateA;
  });

// 获取所有分类
const categories = Array.from(new Set(allPosts.map((post: any) => post.category))).sort();

// 获取所有年份（按倒序）
const years = Array.from(new Set(allPosts.map((post: any) => post.year).filter(Boolean))).sort((a, b) => Number(b) - Number(a));
---

<BaseLayout title="博客 - 木风">
  <style>
    .blog-main-wrap {
      padding: 8px 0 28px;
    }
    .blog-wrapper {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0;
      display: flex;
      gap: 28px;
    }
    .blog-main-left {
      flex: 0 0 248px;
    }
    .blog-main-right {
      flex: 1;
      min-width: 0;
    }

    .blog-slideBar {
      position: sticky;
      top: 16px;
      padding: 22px 20px;
      border-radius: 26px;
      background: rgba(255, 255, 255, 0.78);
      border: 1px solid rgba(142, 175, 156, 0.18);
      box-shadow: 0 22px 52px rgba(89, 124, 106, 0.08);
      backdrop-filter: blur(18px);
    }

    .blog-slideBar .title {
      margin-bottom: 24px;
    }
    .blog-slideBar .title h4 {
      font-family: "Noto Serif SC", serif;
      font-size: 1.5rem;
      font-weight: 700;
      letter-spacing: 0.04em;
      margin-bottom: 6px;
      color: #24332d;
    }
    .blog-slideBar .title p {
      font-size: 0.84rem;
      color: #6c7f75;
    }
    .blog-slideBar .title p i {
      color: #69b38f;
      margin: 0 4px;
    }

    .blog-filter dl {
      margin-bottom: 20px;
    }
    .blog-filter dt {
      margin-bottom: 10px;
    }
    .blog-filter dt .t1 {
      font-size: 0.7rem;
      color: #90a59a;
      letter-spacing: 0.14em;
    }
    .blog-filter dt .t2 {
      font-size: 0.84rem;
      color: #506258;
    }
    .blog-filter dd {
      margin: 6px 0;
    }
    .blog-filter dd a,
    .blog-filter dd button {
      color: #6c7f75;
      text-decoration: none;
      font-size: 0.88rem;
      transition: color 0.28s ease, background 0.28s ease;
      cursor: pointer;
      background: none;
      border: none;
      padding: 8px 10px;
      border-radius: 12px;
      font-family: inherit;
      text-align: left;
      width: 100%;
    }
    .blog-filter dd a:hover,
    .blog-filter dd button:hover,
    .blog-filter dd.active a,
    .blog-filter dd.active button {
      color: #4d9273;
      background: rgba(105, 179, 143, 0.1);
    }

    .blog-content-header {
      margin-bottom: 18px;
      padding: 18px 20px;
      border-radius: 24px;
      background: rgba(255, 255, 255, 0.74);
      border: 1px solid rgba(142, 175, 156, 0.18);
      box-shadow: 0 18px 44px rgba(89, 124, 106, 0.08);
      backdrop-filter: blur(18px);
    }
    .blog-search-box {
      width: 100%;
      padding: 14px 16px;
      font-size: 1rem;
      border: 1px solid rgba(142, 175, 156, 0.22);
      border-radius: 16px;
      background: rgba(250, 253, 251, 0.9);
      color: #24332d;
      transition: all 0.3s ease;
    }
    .blog-search-box:focus {
      outline: none;
      border-color: #69b38f;
      box-shadow: 0 0 0 4px rgba(105, 179, 143, 0.14);
    }
    .blog-search-box::placeholder {
      color: #91a69a;
    }
    .blog-posts-count {
      margin-top: 10px;
      font-size: 0.84rem;
      color: #6c7f75;
    }

    .blog-posts-list {
      list-style: none;
      display: grid;
      gap: 16px;
    }
    .blog-posts-list.hidden {
      display: none !important;
    }
    .blog-post-item {
      background: rgba(255, 255, 255, 0.78);
      border-radius: 22px;
      padding: 22px;
      box-shadow: 0 18px 44px rgba(89, 124, 106, 0.08);
      transition: all 0.3s ease;
      border: 1px solid rgba(142, 175, 156, 0.18);
      backdrop-filter: blur(16px);
    }
    .blog-post-item.hidden {
      display: none !important;
    }
    .blog-post-item:hover {
      transform: translateY(-3px);
      box-shadow: 0 24px 50px rgba(105, 179, 143, 0.14);
    }
    .blog-post-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 12px;
      gap: 15px;
    }
    .blog-post-title-link {
      text-decoration: none;
      color: #24332d;
      font-size: 1.28rem;
      font-weight: 600;
      display: block;
      transition: color 0.3s ease;
      flex: 1;
    }
    .blog-post-title-link:hover {
      color: #4d9273;
    }
    .blog-post-category {
      display: inline-block;
      padding: 6px 12px;
      background: rgba(105, 179, 143, 0.12);
      color: #4d9273;
      border-radius: 999px;
      font-size: 0.72rem;
      font-weight: 500;
      white-space: nowrap;
    }
    .blog-post-meta {
      display: flex;
      align-items: center;
      gap: 14px;
      color: #6c7f75;
      font-size: 0.84rem;
      margin-top: 8px;
    }

    .blog-empty-wrapper {
      min-height: 300px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .blog-empty-state {
      text-align: center;
      padding: 54px 34px;
      color: #90a59a;
      background: rgba(255, 255, 255, 0.78);
      border-radius: 24px;
      border: 1px solid rgba(142, 175, 156, 0.18);
      box-shadow: 0 18px 44px rgba(89, 124, 106, 0.08);
    }
    .blog-empty-state.hidden {
      display: none !important;
    }
    .blog-empty-state-icon {
      font-size: 4rem;
      margin-bottom: 20px;
      opacity: 0.6;
    }
    .blog-empty-state-text {
      font-size: 1.02rem;
      color: #6c7f75;
    }

    @media (max-width: 768px) {
      .blog-wrapper {
        flex-direction: column;
      }
      .blog-main-left {
        flex: none;
      }
      .blog-slideBar {
        position: static;
      }
      .blog-post-header {
        flex-direction: column;
        align-items: flex-start;
      }
      .blog-post-title-link {
        font-size: 1.1rem;
      }
    }
  </style>

  <div class="blog-main-wrap">
    <div class="blog-wrapper">
      <!-- 左侧边栏 -->
      <div class="blog-main-left">
        <div class="blog-slideBar">
          <div class="title">
            <h4>Mufeng Blog</h4>
            <p><i>{</i><span>文章</span><i>}</i></p>
          </div>
          <div class="blog-filter">
            <dl>
              <dt>
                <p class="t1">FILTER</p>
                <p class="t2">分类索引</p>
              </dt>
              <dd class="active">
                <button type="button" class="filter-btn" data-category="all">所有文章</button>
              </dd>
              {categories.map((category) => {
                const count = allPosts.filter((p: any) => p.category === category).length;
                return (
                  <dd>
                    <button type="button" class="filter-btn" data-category={category}>{category} ({count})</button>
                  </dd>
                );
              })}
            </dl>
            <dl>
              <dt>
                <p class="t1">TIMELINE</p>
                <p class="t2">时间线</p>
              </dt>
              <dd class="active">
                <button type="button" class="filter-btn" data-year="all">全部</button>
              </dd>
              {years.map((year) => {
                const count = allPosts.filter((p: any) => p.year === year).length;
                return (
                  <dd>
                    <button type="button" class="filter-btn" data-year={year}>{year} ({count})</button>
                  </dd>
                );
              })}
            </dl>
          </div>
        </div>
      </div>

      <!-- 右侧内容 -->
      <div class="blog-main-right">
        <div class="blog-content-header">
          <input
            type="text"
            id="searchInput"
            class="blog-search-box"
            placeholder=" 搜索文章标题..."
          />
          <div class="blog-posts-count" id="postsCount">
            显示 {allPosts.length} 篇文章
          </div>
        </div>

        <ul class="blog-posts-list" id="postsList">
          {allPosts.map((post: any) => (
            <li
              class="blog-post-item"
              data-category={post.category}
              data-year={post.year}
              data-title={(post.frontmatter?.title || '').toLowerCase()}
            >
              <div class="blog-post-header">
                <a href={post.url} class="blog-post-title-link">
                  {post.frontmatter?.title}
                </a>
                <span class="blog-post-category">{post.category}</span>
              </div>
              <div class="blog-post-meta">
                {post.pubdate && (
                  <div class="post-date">
                    <time>{post.pubdate}</time>
                  </div>
                )}
                <div class="post-reading-time">
                  <span>需要{post.readingTime} 分钟阅读</span>
                </div>
              </div>
            </li>
          ))}
        </ul>

        <div class="blog-empty-wrapper">
          <div class="blog-empty-state hidden" id="emptyState">
            <div class="blog-empty-state-text">没有找到匹配的文章</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    const searchInput = document.getElementById('searchInput');
    const filterButtons = document.querySelectorAll('.filter-btn');
    const postItems = document.querySelectorAll('.blog-post-item');
    const postsCount = document.getElementById('postsCount');
    const emptyState = document.getElementById('emptyState');
    const postsList = document.getElementById('postsList');

    let currentCategory = 'all';
    let currentYear = 'all';
    let currentSearch = '';

    // 搜索
    searchInput?.addEventListener('input', (e) => {
      currentSearch = (e.target as HTMLInputElement).value.toLowerCase().trim();
      filterPosts();
    });

    // 分类和时间线筛选
    filterButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const category = btn.getAttribute('data-category');
        const year = btn.getAttribute('data-year');

        // 更新按钮状态
        const parentDl = btn.closest('dl');
        parentDl?.querySelectorAll('dd').forEach((dd) => dd.classList.remove('active'));
        btn.closest('dd')?.classList.add('active');

        if (category !== null) {
          currentCategory = category;
        }
        if (year !== null) {
          currentYear = year;
        }
        filterPosts();
      });
    });

    function filterPosts() {
      let visibleCount = 0;

      postItems.forEach((item) => {
        const category = item.getAttribute('data-category') || '';
        const year = item.getAttribute('data-year') || '';
        const title = item.getAttribute('data-title') || '';

        const categoryMatch = currentCategory === 'all' || category === currentCategory;
        const yearMatch = currentYear === 'all' || year === currentYear;
        const searchMatch = !currentSearch || title.includes(currentSearch);

        if (categoryMatch && yearMatch && searchMatch) {
          item.classList.remove('hidden');
          visibleCount++;
        } else {
          item.classList.add('hidden');
        }
      });

      if (postsCount) {
        postsCount.textContent = `显示 ${visibleCount} 篇文章`;
      }

      // 空状态显示
      if (emptyState && postsList) {
        if (visibleCount === 0) {
          emptyState.classList.remove('hidden');
          postsList.classList.add('hidden');
        } else {
          emptyState.classList.add('hidden');
          postsList.classList.remove('hidden');
        }
      }
    }
  </script>
</BaseLayout>
