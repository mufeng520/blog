---
import MuseUiIntegrated from '../../components/MuseUiIntegrated';
import ToolEntryBar from '../../components/ToolEntryBar.astro';
---

<html lang="zh">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" type="image/png" href="/integrations/muse-ui/logo.png" />
    <title>MuseUI 视觉设计台 · 木风</title>
    <meta name="description" content="用 AI 生成 UI 原型、封面、信息图和视觉草稿。木风工具箱出品。" />
    <script is:inline>
      window.tailwind = window.tailwind || {};
      window.tailwind.config = {
        darkMode: 'class',
        theme: {
          extend: {
            fontFamily: {
              sans: ['Inter', 'sans-serif'],
            },
          },
        },
      };
    </script>
    <script is:inline src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Noto+Serif+SC:wght@500;700&family=Outfit:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <ToolEntryBar toolName="MuseUI 视觉设计台" toolType="AI 视觉设计" accent="#0f766e" />
    <MuseUiIntegrated client:load />
  </body>
</html>
