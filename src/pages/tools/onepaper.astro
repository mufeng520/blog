---
import HomePreferencesIsland from '../../integrations/onepaper/islands/HomePreferencesIsland';
import HomeProjectCountIsland from '../../integrations/onepaper/islands/HomeProjectCountIsland';
import HomeProjectsIsland from '../../integrations/onepaper/islands/HomeProjectsIsland';
import ToolAppLayout from '../../layouts/ToolAppLayout.astro';
import { onePaperShell } from '../../lib/tool-shells';
---

<ToolAppLayout {...onePaperShell}>
  <main class="min-h-screen bg-stone-50 dark:bg-stone-950 flex flex-col font-sans">
    <div class="flex-1 flex flex-col max-w-7xl mx-auto w-full p-6 md:p-12">
      <header class="mb-4 md:mb-6 flex items-start justify-between gap-4">
        <div class="flex items-center gap-4">
          <HomePreferencesIsland client:only="react" />
          <div class="pt-1">
            <h1 class="text-2xl font-bold text-stone-800 dark:text-stone-100">OnePaper</h1>
            <HomeProjectCountIsland client:only="react" />
          </div>
        </div>
      </header>
      <HomeProjectsIsland client:only="react" />
    </div>
  </main>
</ToolAppLayout>
