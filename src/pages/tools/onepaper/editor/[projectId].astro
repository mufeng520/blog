---
export const prerender = false;

import OnePaperIsland from '../../../../components/OnePaperIsland';
import ToolAppLayout from '../../../../layouts/ToolAppLayout.astro';
import { onePaperFocusedShell } from '../../../../lib/tool-shells';

const { projectId } = Astro.params;

const shell = {
  ...onePaperFocusedShell,
  title: 'OnePaper | 木风',
  description: 'OnePaper 项目编辑器，用于生成和管理 UI 原型、封面、信息图与视觉草稿。',
  toolName: 'OnePaper',
  lang: 'en',
};
---

<ToolAppLayout {...shell}>
  <OnePaperIsland view="editor" projectId={projectId} client:only="react" />
</ToolAppLayout>
