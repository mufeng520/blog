---
import BaseLayout from '../layouts/BaseLayout.astro';
import tools from '../data/tools.json';
import { independentToolCatalogItems, type ToolCatalogItem } from '../lib/tool-apps';

const items = [
  ...independentToolCatalogItems,
  ...(tools as ToolCatalogItem[]),
];
---

<BaseLayout title="工具箱 - 木风">
  <style>
    .tools-page {
      display: grid;
      gap: 22px;
      padding: 8px 0 28px;
    }

    .hero,
    .section-card {
      background: rgba(255, 255, 255, 0.78);
      border: 1px solid rgba(142, 175, 156, 0.18);
      border-radius: 28px;
      box-shadow: 0 22px 54px rgba(89, 124, 106, 0.08);
      backdrop-filter: blur(18px);
    }

    .hero {
      padding: 30px 28px;
      background:
        radial-gradient(circle at top right, rgba(179, 219, 196, 0.4), transparent 30%),
        linear-gradient(155deg, rgba(255,255,255,0.82), rgba(248,252,249,0.72));
    }

    .eyebrow {
      display: inline-flex;
      padding: 7px 12px;
      border-radius: 999px;
      background: rgba(105, 179, 143, 0.12);
      color: #4d9273;
      font-size: 0.78rem;
      letter-spacing: 0.08em;
    }

    .hero h1 {
      margin-top: 14px;
      font-family: "Noto Serif SC", serif;
      font-size: clamp(2rem, 4vw, 2.9rem);
      color: #24332d;
      line-height: 1.28;
    }

    .hero p {
      margin-top: 14px;
      max-width: 740px;
      color: #6c7f75;
      line-height: 1.9;
      font-size: 0.98rem;
    }

    .hero-tags {
      margin-top: 18px;
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    .hero-tag {
      padding: 7px 12px;
      border-radius: 999px;
      background: rgba(255,255,255,0.76);
      border: 1px solid rgba(142, 175, 156, 0.16);
      color: #6c7f75;
      font-size: 0.82rem;
    }

    .section-card {
      padding: 20px 18px;
    }

    .section-title {
      font-size: 1rem;
      font-weight: 700;
      color: #24332d;
      margin-bottom: 14px;
      padding: 0 4px;
    }

    .tool-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 14px;
    }

    .tool-card {
      display: grid;
      gap: 10px;
      padding: 18px;
      border-radius: 22px;
      background: rgba(248, 252, 249, 0.82);
      border: 1px solid rgba(142, 175, 156, 0.16);
    }

    .tool-meta {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      align-items: center;
    }

    .tool-type,
    .tool-status {
      padding: 5px 10px;
      border-radius: 999px;
      font-size: 0.74rem;
    }

    .tool-type {
      background: rgba(105, 179, 143, 0.12);
      color: #4d9273;
    }

    .tool-status {
      background: rgba(255,255,255,0.76);
      border: 1px solid rgba(142, 175, 156, 0.14);
      color: #6c7f75;
    }

    .tool-name {
      font-size: 1.02rem;
      font-weight: 700;
      color: #24332d;
      text-decoration: none;
      line-height: 1.45;
    }

    .tool-name:hover {
      color: #4d9273;
    }

    .tool-desc {
      color: #4f6258;
      font-size: 0.9rem;
      line-height: 1.8;
    }

    .tag-list {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .tag-item {
      padding: 5px 10px;
      border-radius: 999px;
      background: rgba(255,255,255,0.76);
      border: 1px solid rgba(142, 175, 156, 0.14);
      color: #6c7f75;
      font-size: 0.74rem;
    }
  </style>

  <div class="tools-page">
    <section class="hero">
      <div class="eyebrow">Toolbox · 工具箱</div>
      <h1>把自己真正写过、会继续维护的工具放在这里</h1>
      <p>
        这里收的不是概念，而是我已经做出来、或者会持续打磨的东西。它们可能不大，但至少解决过我自己的问题。
      </p>
      <div class="hero-tags">
        <span class="hero-tag">共 {items.length} 个工具</span>
        <span class="hero-tag">直接可访问</span>
        <span class="hero-tag">持续完善中</span>
      </div>
    </section>

    <section class="section-card">
      <div class="section-title">我的工具</div>
      <div class="tool-grid">
        {items.map((item) => (
          <article class="tool-card">
            <div class="tool-meta">
              <span class="tool-type">{item.type}</span>
              <span class="tool-status">{item.status}</span>
            </div>
            <a class="tool-name" href={item.url}>
              {item.name}
            </a>
            <p class="tool-desc">{item.description}</p>
            {item.tags?.length ? (
              <div class="tag-list">
                {item.tags.map((tag) => (
                  <span class="tag-item">#{tag}</span>
                ))}
              </div>
            ) : null}
          </article>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
